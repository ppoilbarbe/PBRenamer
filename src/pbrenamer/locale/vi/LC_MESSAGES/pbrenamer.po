#: /tmp/_pbrenamer_ui_strings.py:147
msgid "Compute rename preview"
msgstr "Tính bản xem trước đổi tên"

#: /tmp/_pbrenamer_ui_strings.py:148
msgid ""
"Apply the current pattern to all listed files and show the result in the "
"Preview column"
msgstr ""
"Áp dụng mẫu hiện tại cho tất cả tệp được liệt kê và hiển thị kết quả "
"trong cột Xem trước"

#: /tmp/_pbrenamer_ui_strings.py:149
msgid "Clear"
msgstr "Xóa"

#: /tmp/_pbrenamer_ui_strings.py:150
msgid "Clear the preview"
msgstr "Xóa bản xem trước"

#: /tmp/_pbrenamer_ui_strings.py:151
msgid "Remove all preview values from the Preview column"
msgstr "Xóa tất cả giá trị xem trước khỏi cột Xem trước"

#: /tmp/_pbrenamer_ui_strings.py:152
msgid "Undo"
msgstr "Hoàn tác"

#: /tmp/_pbrenamer_ui_strings.py:153
msgid "Undo last rename batch"
msgstr "Hoàn tác lô đổi tên cuối cùng"

#: /tmp/_pbrenamer_ui_strings.py:154
msgid "Reverse the last batch of renames performed on disk"
msgstr "Đảo ngược lô đổi tên cuối cùng đã thực hiện trên đĩa"

#: /tmp/_pbrenamer_ui_strings.py:155
msgid "Rename"
msgstr "Đổi tên"

#: /tmp/_pbrenamer_ui_strings.py:156
msgid "Apply renames on disk"
msgstr "Áp dụng đổi tên trên đĩa"

#: /tmp/_pbrenamer_ui_strings.py:157
msgid ""
"Permanently rename all files shown in the Preview column (only enabled when "
"there are no conflicts)"
msgstr ""
"Đổi tên vĩnh viễn tất cả tệp hiển thị trong cột Xem trước (chỉ bật khi "
"không có xung đột)"

#: /tmp/_pbrenamer_ui_strings.py:158
msgid "File"
msgstr "Tệp"

#: /tmp/_pbrenamer_ui_strings.py:159
msgid "Edit"
msgstr "Chỉnh sửa"

#: /tmp/_pbrenamer_ui_strings.py:160
msgid "Help"
msgstr "Trợ giúp"
