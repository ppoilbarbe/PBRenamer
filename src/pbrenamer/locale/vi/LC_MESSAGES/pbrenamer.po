msgstr "Chế độ mẫu"

# ==AUTO== Automatically translated
msgid "Regular expression mode"
msgstr "Chế độ biểu thức chính quy"

# ==AUTO== Automatically translated
msgid "Plain text mode"
msgstr "Chế độ văn bản thuần túy"

# ==AUTO== Automatically translated
#, python-brace-format
msgid ""
"The replacement string is the same regardless of the search mode. Fields "
"are written <code>{name}</code> and may include formatting options:"
msgstr ""
"Chuỗi thay thế giống nhau bất kể chế độ tìm kiếm. Các trường được viết là"
" <code>{name}</code> và có thể bao gồm các tùy chọn định dạng:"

# ==AUTO== Automatically translated
msgid "plain value"
msgstr "giá trị thô"

# ==AUTO== Automatically translated
msgid "with format  (digit = min width · strftime for dates)"
msgstr "có định dạng  (số = chiều rộng tối thiểu · strftime cho ngày)"

# ==AUTO== Automatically translated
msgid "case:   - lower   + upper   ! Caps   * Title   = unchanged"
msgstr "hoa/thường:  - thường   + HOA   ! Đầu Câu   * Mỗi Từ   = không đổi"

# ==AUTO== Automatically translated
msgid "align:  &lt; left   &gt; right   0 zero-pad   ^ centre"
msgstr "căn:  &lt; trái   &gt; phải   0 thêm số 0   ^ giữa"

# ==AUTO== Automatically translated
msgid "all options; default used when field is absent"
msgstr "tất cả tùy chọn; mặc định khi trường vắng mặt"

# ==AUTO== Automatically translated
msgid "literal '{' character"
msgstr "ký tự '{' theo nghĩa đen"

# ==AUTO== Automatically translated
msgid ""
"<b>fmt</b>: minimum width (digit) for text/numbers, or a "
"<code>strftime</code> format for dates/datetimes.<br><b>default</b>: "
"literal fallback used when the field is absent; omitting it flags the "
"file in red in the preview."
msgstr ""
"<b>fmt</b>: chiều rộng tối thiểu (chữ số) cho văn bản/số, hoặc định dạng "
"<code>strftime</code> cho ngày/giờ.<br><b>mặc định</b>: giá trị dự phòng "
"khi trường vắng mặt; bỏ qua sẽ đánh dấu tệp màu đỏ trong bản xem trước."

# ==AUTO== Automatically translated
msgid "all modes"
msgstr "tất cả chế độ"

# ==AUTO== Automatically translated
msgid "pattern, regex"
msgstr "mẫu, regex"

# ==AUTO== Automatically translated
msgid "regex only"
msgstr "chỉ regex"

# ==AUTO== Automatically translated
msgid "Available in"
msgstr "Có sẵn trong"

# ==AUTO== Automatically translated
msgid "Full matched text (or search literal in plain-text mode)"
msgstr "Toàn bộ văn bản khớp (hoặc chuỗi tìm kiếm trong chế độ văn bản thuần túy)"

# ==AUTO== Automatically translated
msgid "Numbered capture groups (1-based)"
msgstr "Nhóm chụp được đánh số (bắt đầu từ 1)"

# ==AUTO== Automatically translated
msgid "Named group <code>(?P&lt;name&gt;…)</code> from the search regex"
msgstr "Nhóm có tên <code>(?P&lt;name&gt;…)</code> từ regex tìm kiếm"

# ==AUTO== Automatically translated
#, python-brace-format
msgid ""
"Auto-incrementing counter — default fmt is a minimum width; "
"<em>default</em> sets the start value (e.g. <code>{num:02:10}</code> "
"starts at 10, zero-padded to 2 digits)"
msgstr ""
"Bộ đếm tự tăng — fmt là chiều rộng tối thiểu; <em>default</em> đặt giá "
"trị bắt đầu (ví dụ <code>{num:02:10}</code> bắt đầu từ 10, đệm số 0 đến 2"
" chữ số)"

# ==AUTO== Automatically translated
#, python-brace-format
msgid ""
"Like <code>{num}</code> but skips values whose target name already exists"
" on disk or has been assigned to another file in the same batch — "
"guarantees no conflicts"
msgstr ""
"Giống <code>{num}</code> nhưng bỏ qua các giá trị có tên đích đã tồn tại "
"trên đĩa hoặc đã được gán cho tệp khác trong cùng lô — đảm bảo không có "
"xung đột"

# ==AUTO== Automatically translated
#, python-format
