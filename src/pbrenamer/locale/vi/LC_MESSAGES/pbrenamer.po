msgstr ""
"Ngày/giờ tạo tệp — fmt mặc định <code>%Y-%m-%d_%H%M%S</code> (thời gian "
"thay đổi inode trên Linux)"

msgid "Name of the immediate parent folder"
msgstr "Tên thư mục cha trực tiếp"

msgid "EXIF or IPTC metadata field (images only — see list below)"
msgstr "Trường siêu dữ liệu EXIF hoặc IPTC (chỉ ảnh — xem danh sách bên dưới)"

msgid "Audio metadata field (mp3, ogg, flac… — see list below)"
