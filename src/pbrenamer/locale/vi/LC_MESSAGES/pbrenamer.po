# ==AUTO== Automatically translated
#, python-brace-format
msgid ""
"Tokens act as typed wildcards. Segments enclosed in <b>{1}</b>, "
"<b>{2}</b>… are <em>captured</em> and available for reuse in the "
"replacement field."
msgstr ""
"Các token hoạt động như ký tự đại diện. Các phần được đặt trong "
"<b>{1}</b>, <b>{2}</b>… được <em>ghi lại</em> và có thể dùng lại trong "
"trường thay thế.Token hoạt động như ký tự đại diện có kiểu. Các đoạn nằm "
"trong <b>{1}</b>, <b>{2}</b>… được <em>chụp lại</em> và có thể tái sử "
"dụng trong trường thay thế."

msgid "One or more digits (0–9)"
msgstr "Một hoặc nhiều chữ số (0–9)"

msgid "One or more letters (a–z, A–Z and Unicode letters)"
msgstr "Một hoặc nhiều chữ cái (a–z, A–Z và chữ cái Unicode)"

msgid "One or more non-whitespace characters"
msgstr "Một hoặc nhiều ký tự không phải khoảng trắng"

msgid "Any sequence of characters, including empty"
msgstr "Bất kỳ chuỗi ký tự nào, kể cả rỗng"

msgid "Trash — matches and discards a segment (not captured)"
msgstr "Thùng rác — khớp và bỏ qua một đoạn (không chụp lại)"

#, python-brace-format
msgid "Capture group — the matched text is bound to {1}, {2}… in the replacement"
msgstr "Nhóm chụp — văn bản khớp được gắn với {1}, {2}… trong phần thay thế"

msgid "Example"
msgstr "Ví dụ"

msgid "Search:"
msgstr "Tìm kiếm:"

msgid "Replace:"
msgstr "Thay thế:"

# ==AUTO== Automatically translated
msgid ""
"Full Python <code>re</code>-module syntax. The match is applied to the "
"file stem (or full name if <em>Keep extension</em> is unchecked)."
msgstr ""
"Cú pháp đầy đủ của mô-đun <code>re</code> Python. Kết quả khớp được áp "
"dụng cho phần tên tệp (hoặc tên đầy đủ nếu <em>Giữ phần mở rộng</em> bị "
"bỏ chọn).Cú pháp đầy đủ của mô-đun <code>re</code> Python. Khớp được áp "
"dụng cho tên cơ sở của tệp (hoặc tên đầy đủ nếu <em>Giữ phần mở rộng</em>"
" bị bỏ chọn)."

msgid "Any single character"
msgstr "Bất kỳ ký tự đơn nào"

msgid "Any sequence (greedy), non-empty variant"
msgstr "Bất kỳ chuỗi nào (tham lam), biến thể không rỗng"

msgid "One or more digits"
msgstr "Một hoặc nhiều chữ số"

msgid "Word characters (letters, digits, _)"
msgstr "Ký tự từ (chữ cái, chữ số, _)"

msgid ""
"Numbered capture group → <code>\\1</code>, <code>\\2</code>… in "
"replacement"
msgstr ""
"Nhóm chụp được đánh số → <code>\\1</code>, <code>\\2</code>… trong phần "
"thay thế"

msgid "Named capture group → <code>\\g&lt;name&gt;</code> in replacement"
msgstr "Nhóm chụp có tên → <code>\\g&lt;name&gt;</code> trong phần thay thế"

msgid "Case-insensitive flag"
msgstr "Cờ không phân biệt chữ hoa/thường"

msgid "Start / end of the name"
msgstr "Đầu / cuối tên"

# ==AUTO== Automatically translated
msgid ""
"The search field is matched as a literal string — no wildcards, no "
"special characters. Every occurrence of the exact text in the file name "
"is replaced."
msgstr ""
"Trường tìm kiếm được so khớp như một chuỗi ký tự thông thường — không có "
"ký tự đại diện, không có ký tự đặc biệt. Mỗi lần xuất hiện văn bản chính "
"xác trong tên tệp đều được thay thế.Trường tìm kiếm được khớp như chuỗi "
"ký tự — không có ký tự đại diện, không có ký tự đặc biệt. Mỗi lần xuất "
"hiện văn bản chính xác trong tên tệp đều được thay thế."

msgid "Search patterns"
msgstr "Mẫu tìm kiếm"

msgid "Pattern mode"
msgstr "Chế độ mẫu"

msgid "Regular expression mode"
msgstr "Chế độ biểu thức chính quy"

msgid "Plain text mode"
msgstr "Chế độ văn bản thuần"

# ==AUTO== Automatically translated
#, python-brace-format
msgid ""
"The replacement string is the same regardless of the search mode. Fields "
"are written <code>{name}</code> and may include formatting options:"
msgstr ""
"Chuỗi thay thế giống nhau bất kể chế độ tìm kiếm. Các trường được viết là"
" <code>{name}</code> và có thể bao gồm các tùy chọn định dạng:"

msgid "plain value"
msgstr "giá trị thuần"

msgid "with format"
msgstr "có định dạng"

msgid "with format and fallback"
msgstr "có định dạng và giá trị dự phòng"

msgid "left-align  (digit fmt = min width)"
msgstr "căn trái  (fmt chữ số = độ rộng tối thiểu)"

msgid "right-align"
msgstr "căn phải"

msgid "zero-pad right (numbers)"
msgstr "đệm số không bên phải (số)"

msgid "literal '{' character"
msgstr "ký tự '{' theo nghĩa đen"

# ==AUTO== Automatically translated
msgid ""
"<b>fmt</b> is a minimum width (digit) for text/numbers, or a "
"<code>strftime</code> format for dates/datetimes.<br><b>default</b>: used"
" when the field is absent; omitting it makes absence an error (file shown"
" in red in the preview)."
msgstr ""
"<b>fmt</b> là chiều rộng tối thiểu (chữ số) cho văn bản/số, hoặc định "
"dạng <code>strftime</code> cho ngày/giờ.<br><b>default</b>: được dùng khi"
" trường vắng mặt; bỏ qua sẽ khiến sự vắng mặt trở thành lỗi (tệp hiển thị"
" màu đỏ trong bản xem trước).<b>fmt</b> là độ rộng tối thiểu (chữ số) cho"
" văn bản/số, hoặc định dạng <code>strftime</code> cho "
"ngày/giờ.<br><b>default</b>: được dùng khi trường vắng mặt; bỏ qua nó làm"
" sự vắng mặt thành lỗi (tệp hiển thị màu đỏ trong bản xem trước)."

msgid "all modes"
msgstr "tất cả chế độ"

msgid "pattern, regex"
msgstr "mẫu, regex"

msgid "regex only"
msgstr "chỉ regex"

msgid "Field"
msgstr "Trường"

msgid "Available in"
msgstr "Có sẵn trong"

msgid "Description"
msgstr "Mô tả"

msgid "Full matched text (or search literal in plain-text mode)"
msgstr "Toàn bộ văn bản khớp (hoặc chuỗi tìm kiếm trong chế độ văn bản thuần)"

msgid "Numbered capture groups (1-based)"
msgstr "Nhóm chụp được đánh số (bắt đầu từ 1)"

msgid "Named group <code>(?P&lt;name&gt;…)</code> from the search regex"
msgstr "Nhóm có tên <code>(?P&lt;name&gt;…)</code> từ regex tìm kiếm"

# ==AUTO== Automatically translated
#, python-brace-format
msgid ""
"Auto-incrementing counter — default fmt is a minimum width; "
"<em>default</em> sets the start value (e.g. <code>{num:02:10}</code> "
"starts at 10, zero-padded to 2 digits)"
msgstr ""
"Bộ đếm tự tăng — fmt là chiều rộng tối thiểu; <em>default</em> đặt giá "
"trị bắt đầu (vd. <code>{num:02:10}</code> bắt đầu từ 10, bổ sung 0 đến 2 "
"chữ số)Bộ đếm tự tăng — fmt mặc định là độ rộng tối thiểu; "
"<em>default</em> đặt giá trị bắt đầu (vd. <code>{num:02:10}</code> bắt "
"đầu từ 10, đệm số không thành 2 chữ số)"

# ==AUTO== Automatically translated
#, python-brace-format
msgid ""
"Like <code>{num}</code> but skips values whose target name already exists"
" on disk or has been assigned to another file in the same batch — "
"guarantees no conflicts"
msgstr ""
"Giống <code>{num}</code> nhưng bỏ qua các giá trị mà tên đích đã tồn tại "
"trên đĩa hoặc đã được gán cho tệp khác trong cùng lô — đảm bảo không có "
"xung đột"

#, python-format
msgid "Today's date — default fmt <code>%Y-%m-%d</code>"
msgstr "Ngày hôm nay — định dạng mặc định <code>%Y-%m-%d</code>"

#, python-format
msgid "Current date and time — default fmt <code>%Y-%m-%d_%H%M%S</code>"
msgstr "Ngày và giờ hiện tại — định dạng mặc định <code>%Y-%m-%d_%H%M%S</code>"

#, python-format
msgid "File modification date/time — default fmt <code>%Y-%m-%d_%H%M%S</code>"
msgstr "Ngày/giờ sửa đổi tệp — định dạng mặc định <code>%Y-%m-%d_%H%M%S</code>"

# ==AUTO== Automatically translated
#, python-format
msgid ""
"File creation date/time — default fmt <code>%Y-%m-%d_%H%M%S</code> (inode"
