# ==AUTO== Automatically translated
#: src/pbrenamer/ui/pattern_help.py:339
msgid ""
"Field names are case-insensitive. Supported formats: mp3, ogg, flac, "
"opus, aac/m4a and others supported by mutagen. A <b>default</b> is "
"strongly recommended — tags may be absent or the file may not be a "
"supported audio format."
msgstr ""
"Имена полей нечувствительны к регистру. Поддерживаемые форматы: mp3, ogg,"
" flac, opus, aac/m4a и другие, поддерживаемые mutagen. Настоятельно "
"рекомендуется <b>default</b> — теги могут отсутствовать или файл может не"
" быть поддерживаемым аудиоформатом.Имена полей нечувствительны к "
"регистру. Поддерживаемые форматы: mp3, ogg, flac, opus, aac/m4a и другие "
"форматы, поддерживаемые mutagen. Значение <b>default</b> настоятельно "
"рекомендуется — теги могут отсутствовать или файл может не быть "
"поддерживаемым аудиоформатом."

