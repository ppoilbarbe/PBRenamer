# ==AUTO== Automatically translated
#, python-brace-format
msgid ""
"The replacement string is the same regardless of the search mode. Fields "
"are written <code>{name}</code> and may include formatting options:"
msgstr ""
"La cadena de reemplazo es la misma independientemente del modo de "
"búsqueda. Los campos se escriben <code>{name}</code> y pueden incluir "
"opciones de formato:"

# ==AUTO== Automatically translated
msgid "plain value"
msgstr "valor simple"

# ==AUTO== Automatically translated
msgid "with format  (digit = min width · strftime for dates)"
msgstr "con formato  (dígito = ancho mínimo · strftime para fechas)"

# ==AUTO== Automatically translated
