msgstr "选择行以将操作限制到这些文件；不选则应用到所有文件"

msgid "Search pattern"
msgstr "搜索模式"

#, python-brace-format
msgid ""
"Pattern to match against file names. Use tokens: {#} numbers, {L} "
"letters, {C} non-space, {X} anything"
msgstr "用于匹配文件名的模式。使用令牌：{#} 数字，{L} 字母，{C} 非空白，{X} 任意"

msgid "Save to history"
msgstr "保存到历史"

msgid "Add the current search pattern and mode to the drop-down history"
msgstr "将当前搜索模式和模式添加到下拉历史"

msgid "Search pattern help"
msgstr "搜索模式帮助"

msgid ""
"Show help about search patterns (Pattern tokens, Regular expressions, "
"Plain text)"
msgstr "显示搜索模式帮助（模式令牌、正则表达式、纯文本）"

msgid "Pattern"
msgstr "模式"

msgid "Search using pattern tokens"
msgstr "使用模式令牌搜索"

#, python-brace-format
msgid "Match file names using pattern tokens ({#}, {L}, {X}…)"
msgstr "使用模式令牌匹配文件名（{#}、{L}、{X}…）"

msgid "Regular expression"
msgstr "正则表达式"

msgid "Search using a Python regular expression"
msgstr "使用 Python 正则表达式搜索"

msgid ""
"Match file names using a Python regular expression; use \\1 \\2… for "
"backreferences in the replacement"
msgstr "使用 Python 正则表达式匹配文件名；在替换中使用 \\1 \\2… 作为反向引用"

msgid "Plain text"
msgstr "纯文本"

msgid "Search for a literal string"
msgstr "搜索字面字符串"

msgid "Match file names by looking for the search text as a literal string"
msgstr "通过将搜索文本作为字面字符串查找来匹配文件名"

# ==AUTO== Automatically translated
msgid "Case-insensitive"
msgstr "忽略大小写"

# ==AUTO== Automatically translated
msgid "Ignore case when searching"
msgstr "搜索时忽略大小写"

# ==AUTO== Automatically translated
msgid ""
"When checked, the search pattern matches file names regardless of letter "
"case"
msgstr "勾选后，搜索模式匹配文件名时不区分大小写"

msgid "Replacement pattern"
msgstr "替换模式"

#, python-brace-format
msgid ""
"Replacement pattern. Use {1} {2}… for capture groups, {num} for a "
"counter, {date} for today's date, {dir} for the parent folder name"
msgstr "替换模式。使用 {1} {2}… 表示捕获组，{num} 表示计数器，{date} 表示今天的日期，{dir} 表示父文件夹名称"

msgid "Add the current replacement pattern to the drop-down history"
msgstr "将当前替换模式添加到下拉历史"

msgid "Replacement pattern help"
msgstr "替换模式帮助"

msgid ""
"Show help about replacement patterns (capture groups, counter, date, "
"directory tokens)"
msgstr "显示替换模式帮助（捕获组、计数器、日期、目录令牌）"

