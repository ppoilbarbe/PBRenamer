msgstr "将带重音字符转换为其 ASCII 等效字符（é→e、ü→u 等）"

msgid "Remove duplicate separators"
msgstr "删除重复分隔符"

msgid "Collapse consecutive separators"
msgstr "合并连续分隔符"

msgid ""
"Collapse runs of identical separator characters (spaces, dots, dashes, "
"underscores) into one"
msgstr "将连续相同的分隔符（空格、点、连字符、下划线）合并为一个"

msgid "Case:"
msgstr "大小写："

msgid "UPPERCASE"
msgstr "全大写"

msgid "lowercase"
msgstr "全小写"

msgid "Capitalize first letter"
msgstr "首字母大写"

msgid "Title Case"
msgstr "每个单词首字母大写"

