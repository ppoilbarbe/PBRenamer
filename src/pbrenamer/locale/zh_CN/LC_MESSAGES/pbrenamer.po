#: src/pbrenamer/ui/pattern_help.py:73
#, python-brace-format
msgid ""
"Tokens act as typed wildcards. Segments enclosed in <b>{1}</b>, "
"<b>{2}</b>… are <em>captured</em> and available for reuse in the "
"replacement field."
msgstr "令牌充当有类型的通配符。包含在 <b>{1}</b>、<b>{2}</b>… 中的片段将被<em>捕获</em>，可在替换字段中重复使用。"

#: src/pbrenamer/ui/pattern_help.py:78
msgid "One or more digits (0–9)"
msgstr "一个或多个数字（0–9）"

#: src/pbrenamer/ui/pattern_help.py:79
msgid "One or more letters (a–z, A–Z and Unicode letters)"
msgstr "一个或多个字母（a–z、A–Z 及 Unicode 字母）"

#: src/pbrenamer/ui/pattern_help.py:80
msgid "One or more non-whitespace characters"
msgstr "一个或多个非空白字符"

#: src/pbrenamer/ui/pattern_help.py:81
msgid "Any sequence of characters, including empty"
msgstr "任意字符序列，包括空序列"

#: src/pbrenamer/ui/pattern_help.py:82
msgid "Trash — matches and discards a segment (not captured)"
msgstr "垃圾桶——匹配并丢弃一个片段（不捕获）"

#: src/pbrenamer/ui/pattern_help.py:86
#, python-brace-format
msgid "Capture group — the matched text is bound to {1}, {2}… in the replacement"
msgstr "捕获组——匹配的文本绑定到替换中的 {1}、{2}…"

#: src/pbrenamer/ui/pattern_help.py:94 src/pbrenamer/ui/pattern_help.py:134
#: src/pbrenamer/ui/pattern_help.py:150
msgid "Example"
msgstr "示例"

#: src/pbrenamer/ui/pattern_help.py:96 src/pbrenamer/ui/pattern_help.py:136
#: src/pbrenamer/ui/pattern_help.py:152 tools/_ui_strings_tmp.py:84
msgid "Search:"
msgstr "搜索："

#: src/pbrenamer/ui/pattern_help.py:98 src/pbrenamer/ui/pattern_help.py:138
#: src/pbrenamer/ui/pattern_help.py:154 tools/_ui_strings_tmp.py:103
msgid "Replace:"
msgstr "替换："

#: src/pbrenamer/ui/pattern_help.py:105
msgid ""
"Full Python <code>re</code>-module syntax. The match is applied to the "
"file stem (or full name if <em>Keep extension</em> is unchecked)."
msgstr "完整的 Python <code>re</code> 模块语法。匹配应用于文件名主干（如果<em>保留扩展名</em>未勾选，则应用于完整名称）。"

#: src/pbrenamer/ui/pattern_help.py:110
msgid "Any single character"
msgstr "任意单个字符"

#: src/pbrenamer/ui/pattern_help.py:112
msgid "Any sequence (greedy), non-empty variant"
msgstr "任意序列（贪婪），非空变体"

#: src/pbrenamer/ui/pattern_help.py:114
msgid "One or more digits"
msgstr "一个或多个数字"

#: src/pbrenamer/ui/pattern_help.py:115
msgid "Word characters (letters, digits, _)"
msgstr "单词字符（字母、数字、_）"

#: src/pbrenamer/ui/pattern_help.py:119
msgid ""
"Numbered capture group → <code>\\1</code>, <code>\\2</code>… in "
"replacement"
msgstr "编号捕获组 → 替换中的 <code>\\1</code>、<code>\\2</code>…"

#: src/pbrenamer/ui/pattern_help.py:126
msgid "Named capture group → <code>\\g&lt;name&gt;</code> in replacement"
msgstr "命名捕获组 → 替换中的 <code>\\g&lt;name&gt;</code>"

#: src/pbrenamer/ui/pattern_help.py:128
msgid "Case-insensitive flag"
msgstr "不区分大小写标志"

#: src/pbrenamer/ui/pattern_help.py:129
msgid "Start / end of the name"
msgstr "名称的开头 / 结尾"

#: src/pbrenamer/ui/pattern_help.py:145
msgid ""
"The search field is matched as a literal string — no wildcards, no "
"special characters. Every occurrence of the exact text in the file name "
"is replaced."
msgstr "搜索字段作为字面字符串进行匹配——没有通配符，没有特殊字符。文件名中每次出现的精确文本都会被替换。"

#: src/pbrenamer/ui/pattern_help.py:161
msgid "Search patterns"
msgstr "搜索模式"

#: src/pbrenamer/ui/pattern_help.py:162
msgid "Pattern mode"
msgstr "模式令牌模式"

#: src/pbrenamer/ui/pattern_help.py:167 tools/_ui_strings_tmp.py:10
msgid "Regular expression mode"
msgstr "正则表达式模式"

#: src/pbrenamer/ui/pattern_help.py:172 tools/_ui_strings_tmp.py:12
msgid "Plain text mode"
msgstr "纯文本模式"

#: src/pbrenamer/ui/pattern_help.py:183
#, python-brace-format
msgid ""
"The replacement string is the same regardless of the search mode. Fields "
"are written <code>{name}</code> and may include formatting options:"
msgstr "无论搜索模式如何，替换字符串都相同。字段写作 <code>{name}</code>，可包含格式化选项："

#: src/pbrenamer/ui/pattern_help.py:188
msgid "plain value"
msgstr "普通值"

#: src/pbrenamer/ui/pattern_help.py:189
msgid "with format"
msgstr "带格式"

#: src/pbrenamer/ui/pattern_help.py:190
msgid "with format and fallback"
msgstr "带格式和回退值"

#: src/pbrenamer/ui/pattern_help.py:191
msgid "left-align  (digit fmt = min width)"
msgstr "左对齐  （数字格式 = 最小宽度）"

#: src/pbrenamer/ui/pattern_help.py:192
msgid "right-align"
msgstr "右对齐"

#: src/pbrenamer/ui/pattern_help.py:193
msgid "zero-pad right (numbers)"
msgstr "右侧补零（数字）"

#: src/pbrenamer/ui/pattern_help.py:194
msgid "literal '{' character"
msgstr "字面 '{' 字符"

# ==AUTO== Automatically translated
#: src/pbrenamer/ui/pattern_help.py:198
msgid ""
"<b>fmt</b> is a minimum width (digit) for text/numbers, or a "
"<code>strftime</code> format for dates/datetimes.<br><b>default</b>: used"
" when the field is absent; omitting it makes absence an error (file shown"
" in red in the preview)."
msgstr ""
"<b>fmt</b> 是文本/数字的最小宽度（数字），或日期/时间的 <code>strftime</code> "
"格式。<br><b>default</b>：字段缺失时使用；省略则缺失为错误（预览中文件显示为红色）。<b>fmt</b> "
"是文本/数字的最小宽度（数字），或日期/时间的 <code>strftime</code> "
"格式。<br><b>default</b>：当字段缺失时使用；省略它会使缺失成为错误（文件在预览中显示为红色）。"

#: src/pbrenamer/ui/pattern_help.py:205
msgid "all modes"
msgstr "所有模式"

#: src/pbrenamer/ui/pattern_help.py:206
msgid "pattern, regex"
msgstr "模式，正则"

#: src/pbrenamer/ui/pattern_help.py:207
msgid "regex only"
msgstr "仅正则"

#: src/pbrenamer/ui/file_info_window.py:71 src/pbrenamer/ui/pattern_help.py:208
msgid "Field"
msgstr "字段"

#: src/pbrenamer/ui/pattern_help.py:209
msgid "Available in"
msgstr "适用于"

#: src/pbrenamer/ui/file_info_window.py:71 src/pbrenamer/ui/pattern_help.py:210
msgid "Description"
msgstr "描述"

#: src/pbrenamer/ui/pattern_help.py:221
msgid "Full matched text (or search literal in plain-text mode)"
msgstr "完整匹配文本（或纯文本模式下的搜索字面量）"

#: src/pbrenamer/ui/pattern_help.py:227
msgid "Numbered capture groups (1-based)"
msgstr "编号捕获组（从 1 开始）"

#: src/pbrenamer/ui/pattern_help.py:232
msgid "Named group <code>(?P&lt;name&gt;…)</code> from the search regex"
msgstr "搜索正则中的命名组 <code>(?P&lt;name&gt;…)</code>"

# ==AUTO== Automatically translated
#: src/pbrenamer/ui/pattern_help.py:239
#, python-brace-format
msgid ""
"Auto-incrementing counter — default fmt is a minimum width; "
"<em>default</em> sets the start value (e.g. <code>{num:02:10}</code> "
"starts at 10, zero-padded to 2 digits)"
msgstr ""
"自动递增计数器 — fmt 为最小宽度；<em>default</em> 设置起始值（例如 <code>{num:02:10}</code> 从 "
"10 开始，补零至 2 位）自动递增计数器——默认格式为最小宽度；<em>default</em> 设置起始值（例如 "
"<code>{num:02:10}</code> 从 10 开始，补零到 2 位）"

#: src/pbrenamer/ui/pattern_help.py:248
#, python-brace-format
msgid ""
"Like <code>{num}</code> but skips values whose target name already exists"
" on disk or has been assigned to another file in the same batch — "
"guarantees no conflicts"
msgstr "类似 <code>{num}</code>，但跳过目标名称已存在于磁盘或已分配给同一批次另一文件的值——保证无冲突"

#: src/pbrenamer/ui/pattern_help.py:257
#, python-format
msgid "Today's date — default fmt <code>%Y-%m-%d</code>"
msgstr "今天的日期——默认格式 <code>%Y-%m-%d</code>"

#: src/pbrenamer/ui/pattern_help.py:263
#, python-format
msgid "Current date and time — default fmt <code>%Y-%m-%d_%H%M%S</code>"
msgstr "当前日期和时间——默认格式 <code>%Y-%m-%d_%H%M%S</code>"

#: src/pbrenamer/ui/pattern_help.py:268
#, python-format
msgid "File modification date/time — default fmt <code>%Y-%m-%d_%H%M%S</code>"
msgstr "文件修改日期/时间——默认格式 <code>%Y-%m-%d_%H%M%S</code>"

#: src/pbrenamer/ui/pattern_help.py:275
#, python-format
msgid ""
"File creation date/time — default fmt <code>%Y-%m-%d_%H%M%S</code> (inode"
" change time on Linux)"
msgstr "文件创建日期/时间——默认格式 <code>%Y-%m-%d_%H%M%S</code>（Linux 上的 inode 更改时间）"

#: src/pbrenamer/ui/pattern_help.py:279
msgid "Name of the immediate parent folder"
msgstr "直接父文件夹的名称"

#: src/pbrenamer/ui/pattern_help.py:283
msgid "EXIF or IPTC metadata field (images only — see list below)"
msgstr "EXIF 或 IPTC 元数据字段（仅图像——见下方列表）"

#: src/pbrenamer/ui/pattern_help.py:288
msgid "Audio metadata field (mp3, ogg, flac… — see list below)"
msgstr "音频元数据字段（mp3、ogg、flac…——见下方列表）"

#: src/pbrenamer/ui/pattern_help.py:294
msgid "Video metadata field (mp4, mkv, avi… — see list below)"
msgstr "视频元数据字段（mp4、mkv、avi…——见下方列表）"

#: src/pbrenamer/ui/pattern_help.py:300
msgid ""
"Field names are case-insensitive. A <b>default</b> is strongly "
"recommended for metadata fields — they may be absent from non-image files"
" or images without metadata."
msgstr "字段名称不区分大小写。强烈建议为元数据字段设置 <b>default</b> 值——这些字段在非图像文件或没有元数据的图像中可能缺失。"

