# ==AUTO== Automatically translated
#: src/pbrenamer/ui/pattern_help.py:105
msgid ""
"Full Python <code>re</code>-module syntax. The match is applied to the "
"file stem (or full name if <em>Keep extension</em> is unchecked)."
msgstr ""
"Vollständige Python-<code>re</code>-Modul-Syntax. Die Übereinstimmung "
"wird auf den Dateinamen ohne Erweiterung angewendet (oder auf den "
"vollständigen Namen, wenn <em>Erweiterung beibehalten</em> deaktiviert "
"ist).Vollständige Syntax des Python-Moduls <code>re</code>. Die "
"Übereinstimmung wird auf den Dateinamen ohne Erweiterung angewendet (oder"
" den vollständigen Namen, wenn <em>Erweiterung behalten</em> deaktiviert "
"ist)."

