# ==AUTO== Automatically translated
#, python-brace-format
msgid ""
"Field names are case-insensitive. When <code>{im:…}</code> is combined "
"with <code>{vi:…}</code> or <code>{au:…}</code> in the same template, "
"non-matching fields are silently empty — no default needed. With only "
"<code>{im:…}</code> fields, a default is recommended to avoid flagging "
"non-image files in red."
msgstr ""
"Feldnamen unterscheiden nicht zwischen Groß- und Kleinschreibung. Wenn "
"<code>{im:…}</code> mit <code>{vi:…}</code> oder <code>{au:…}</code> in "
"derselben Vorlage kombiniert wird, sind nicht übereinstimmende Felder "
"stillschweigend leer — kein Standardwert erforderlich. Mit nur "
"<code>{im:…}</code>-Feldern wird ein Standardwert empfohlen, um Nicht-"
"Bilddateien nicht rot zu markieren."

