"The replacement string is the same regardless of the search mode. Fields "
"are written <code>{name}</code> and may include formatting options:"
msgstr ""
"Die Ersetzungszeichenkette ist unabhängig vom Suchmodus gleich. Felder "
"werden als <code>{name}</code> geschrieben und können "
"Formatierungsoptionen enthalten:"

# ==AUTO== Automatically translated
msgid "plain value"
msgstr "einfacher Wert"

# ==AUTO== Automatically translated
msgid "with format  (digit = min width · strftime for dates)"
msgstr "mit Format  (Ziffer = Mindestbreite · strftime für Datumsangaben)"

# ==AUTO== Automatically translated
msgid "case:   - lower   + upper   ! Caps   * Title   = unchanged"
msgstr ""
