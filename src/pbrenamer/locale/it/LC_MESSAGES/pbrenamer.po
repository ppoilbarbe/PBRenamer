msgstr "Caratteri di parola (lettere, cifre, _)"

#: src/pbrenamer/ui/pattern_help.py:119
msgid ""
"Numbered capture group → <code>\\1</code>, <code>\\2</code>… in "
"replacement"
msgstr ""
"Gruppo di cattura numerato → <code>\\1</code>, <code>\\2</code>… nella "
"sostituzione"

#: src/pbrenamer/ui/pattern_help.py:126
msgid "Named capture group → <code>\\g&lt;name&gt;</code> in replacement"
msgstr ""
"Gruppo di cattura denominato → <code>\\g&lt;name&gt;</code> nella "
"sostituzione"

#: src/pbrenamer/ui/pattern_help.py:128
msgid "Case-insensitive flag"
msgstr "Flag senza distinzione tra maiuscole e minuscole"

#: src/pbrenamer/ui/pattern_help.py:129
msgid "Start / end of the name"
msgstr "Inizio / fine del nome"

# ==AUTO== Automatically translated
#: src/pbrenamer/ui/pattern_help.py:145
msgid ""
"The search field is matched as a literal string — no wildcards, no "
"special characters. Every occurrence of the exact text in the file name "
"is replaced."
msgstr ""
"Il campo di ricerca viene confrontato come stringa letterale — nessun "
"jolly, nessun carattere speciale. Ogni occorrenza del testo esatto nel "
"nome file viene sostituita.Il campo di ricerca viene confrontato come "
"stringa letterale — nessun carattere jolly, nessun carattere speciale. "
"Ogni occorrenza del testo esatto nel nome del file viene sostituita."

#: src/pbrenamer/ui/pattern_help.py:161
msgid "Search patterns"
msgstr "Pattern di ricerca"

#: src/pbrenamer/ui/pattern_help.py:162
msgid "Pattern mode"
msgstr "Modalità pattern"

#: src/pbrenamer/ui/pattern_help.py:167 tools/_ui_strings_tmp.py:10
msgid "Regular expression mode"
msgstr "Modalità espressione regolare"

#: src/pbrenamer/ui/pattern_help.py:172 tools/_ui_strings_tmp.py:12
msgid "Plain text mode"
msgstr "Modalità testo normale"

# ==AUTO== Automatically translated
#: src/pbrenamer/ui/pattern_help.py:183
#, python-brace-format
msgid ""
"The replacement string is the same regardless of the search mode. Fields "
"are written <code>{name}</code> and may include formatting options:"
msgstr ""
"La stringa di sostituzione è la stessa indipendentemente dalla modalità "
"di ricerca. I campi si scrivono <code>{name}</code> e possono includere "
"opzioni di formattazione:"

#: src/pbrenamer/ui/pattern_help.py:188
msgid "plain value"
msgstr "valore semplice"

#: src/pbrenamer/ui/pattern_help.py:189
msgid "with format"
msgstr "con formato"

#: src/pbrenamer/ui/pattern_help.py:190
msgid "with format and fallback"
msgstr "con formato e valore alternativo"

#: src/pbrenamer/ui/pattern_help.py:191
msgid "left-align  (digit fmt = min width)"
msgstr "allineamento a sinistra  (fmt cifra = larghezza minima)"

#: src/pbrenamer/ui/pattern_help.py:192
msgid "right-align"
msgstr "allineamento a destra"

#: src/pbrenamer/ui/pattern_help.py:193
msgid "zero-pad right (numbers)"
msgstr "riempimento con zeri a destra (numeri)"

#: src/pbrenamer/ui/pattern_help.py:194
msgid "literal '{' character"
msgstr "carattere '{' letterale"

# ==AUTO== Automatically translated
#: src/pbrenamer/ui/pattern_help.py:198
msgid ""
"<b>fmt</b> is a minimum width (digit) for text/numbers, or a "
"<code>strftime</code> format for dates/datetimes.<br><b>default</b>: used"
" when the field is absent; omitting it makes absence an error (file shown"
" in red in the preview)."
msgstr ""
"<b>fmt</b> è una larghezza minima (cifra) per testo/numeri, o un formato "
"<code>strftime</code> per date/ore.<br><b>default</b>: usato quando il "
"campo è assente; ometterlo rende l'assenza un errore (file in rosso "
"nell'anteprima).<b>fmt</b> è una larghezza minima (cifra) per "
"testo/numeri, o un formato <code>strftime</code> per "
"date/orari.<br><b>default</b>: usato quando il campo è assente; ometterlo"
" rende l'assenza un errore (il file viene mostrato in rosso "
"nell'anteprima)."

#: src/pbrenamer/ui/pattern_help.py:205
msgid "all modes"
msgstr "tutte le modalità"

#: src/pbrenamer/ui/pattern_help.py:206
msgid "pattern, regex"
msgstr "pattern, regex"

#: src/pbrenamer/ui/pattern_help.py:207
msgid "regex only"
msgstr "solo regex"

#: src/pbrenamer/ui/file_info_window.py:71 src/pbrenamer/ui/pattern_help.py:208
msgid "Field"
