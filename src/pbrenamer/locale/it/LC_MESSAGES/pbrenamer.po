# ==AUTO== Automatically translated
#, python-brace-format
msgid ""
"Field names are case-insensitive. When <code>{im:…}</code> is combined "
"with <code>{vi:…}</code> or <code>{au:…}</code> in the same template, "
"non-matching fields are silently empty — no default needed. With only "
"<code>{im:…}</code> fields, a default is recommended to avoid flagging "
"non-image files in red."
msgstr ""
"I nomi dei campi non fanno distinzione tra maiuscole e minuscole. Quando "
"<code>{im:…}</code> è combinato con <code>{vi:…}</code> o "
"<code>{au:…}</code> nello stesso modello, i campi non corrispondenti sono"
" silenziosamente vuoti — nessun valore predefinito necessario. Con soli "
"campi <code>{im:…}</code>, è consigliato un valore predefinito per "
"evitare di evidenziare in rosso i file non immagine."

