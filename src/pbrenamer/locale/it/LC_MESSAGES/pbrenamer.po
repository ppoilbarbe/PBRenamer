#: src/pbrenamer/ui/settings_dialog.py:19
msgid "System default"
msgstr "Predefinito di sistema"

#: src/pbrenamer/ui/pattern_help.py:76
#, python-brace-format
msgid ""
"Tokens act as typed wildcards. Segments enclosed in <b>{1}</b>, <b>{2}</b>… "
"are <em>captured</em> and available for reuse in the replacement field."
msgstr ""
"I token fungono da caratteri jolly tipizzati. I segmenti racchiusi in "
"<b>{1}</b>, <b>{2}</b>… sono <em>catturati</em> e disponibili per il "
"riutilizzo nel campo di sostituzione."

#: src/pbrenamer/ui/pattern_help.py:81
msgid "One or more digits (0–9)"
msgstr "Una o più cifre (0–9)"

#: src/pbrenamer/ui/pattern_help.py:82
msgid "One or more letters (a–z, A–Z and Unicode letters)"
msgstr "Una o più lettere (a–z, A–Z e lettere Unicode)"

#: src/pbrenamer/ui/pattern_help.py:83
msgid "One or more non-whitespace characters"
msgstr "Uno o più caratteri senza spazi"

#: src/pbrenamer/ui/pattern_help.py:84
msgid "Any sequence of characters, including empty"
msgstr "Qualsiasi sequenza di caratteri, inclusa vuota"

#: src/pbrenamer/ui/pattern_help.py:85
msgid "Trash — matches and discards a segment (not captured)"
msgstr "Cestino — corrisponde a un segmento e lo scarta (non catturato)"

#: src/pbrenamer/ui/pattern_help.py:89
#, python-brace-format
msgid ""
"Capture group — the matched text is bound to {1}, {2}… in the replacement"
msgstr ""
"Gruppo di cattura — il testo corrispondente è associato a {1}, {2}… nella "
"sostituzione"

#: src/pbrenamer/ui/pattern_help.py:97 src/pbrenamer/ui/pattern_help.py:137
#: src/pbrenamer/ui/pattern_help.py:153
msgid "Example"
msgstr "Esempio"

#: src/pbrenamer/ui/pattern_help.py:99 src/pbrenamer/ui/pattern_help.py:139
#: src/pbrenamer/ui/pattern_help.py:155 /tmp/_pbrenamer_ui_strings.py:89
msgid "Search:"
msgstr "Cerca:"

#: src/pbrenamer/ui/pattern_help.py:101 src/pbrenamer/ui/pattern_help.py:141
#: src/pbrenamer/ui/pattern_help.py:157 /tmp/_pbrenamer_ui_strings.py:105
msgid "Replace:"
msgstr "Sostituisci:"

#: src/pbrenamer/ui/pattern_help.py:108
msgid ""
"Full Python <code>re</code>-module syntax. The match is applied to the file "
"stem (or full name if <em>Keep extension</em> is unchecked)."
msgstr ""
"Sintassi completa del modulo Python <code>re</code>. La corrispondenza viene "
"applicata al nome base del file (o al nome completo se "
"<em>Mantieni estensione</em> è deselezionato)."

#: src/pbrenamer/ui/pattern_help.py:113
msgid "Any single character"
msgstr "Qualsiasi singolo carattere"

#: src/pbrenamer/ui/pattern_help.py:115
msgid "Any sequence (greedy), non-empty variant"
msgstr "Qualsiasi sequenza (greedy), variante non vuota"

#: src/pbrenamer/ui/pattern_help.py:117
msgid "One or more digits"
msgstr "Una o più cifre"

#: src/pbrenamer/ui/pattern_help.py:118
msgid "Word characters (letters, digits, _)"
msgstr "Caratteri di parola (lettere, cifre, _)"

#: src/pbrenamer/ui/pattern_help.py:122
msgid ""
"Numbered capture group → <code>\\1</code>, <code>\\2</code>… in replacement"
msgstr ""
"Gruppo di cattura numerato → <code>\\1</code>, <code>\\2</code>… nella "
"sostituzione"

#: src/pbrenamer/ui/pattern_help.py:129
msgid "Named capture group → <code>\\g&lt;name&gt;</code> in replacement"
msgstr ""
"Gruppo di cattura denominato → <code>\\g&lt;name&gt;</code> nella sostituzione"

#: src/pbrenamer/ui/pattern_help.py:131
msgid "Case-insensitive flag"
msgstr "Flag senza distinzione tra maiuscole e minuscole"

#: src/pbrenamer/ui/pattern_help.py:132
msgid "Start / end of the name"
msgstr "Inizio / fine del nome"

#: src/pbrenamer/ui/pattern_help.py:148
msgid ""
"The search field is matched as a literal string — no wildcards, no special "
"characters. Every occurrence of the exact text in the file name is replaced."
msgstr ""
"Il campo di ricerca viene confrontato come stringa letterale — nessun "
"carattere jolly, nessun carattere speciale. Ogni occorrenza del testo esatto "
"nel nome del file viene sostituita."

#: src/pbrenamer/ui/pattern_help.py:164
msgid "Search patterns"
msgstr "Pattern di ricerca"

#: src/pbrenamer/ui/pattern_help.py:165
msgid "Pattern mode"
msgstr "Modalità pattern"

#: src/pbrenamer/ui/pattern_help.py:170 /tmp/_pbrenamer_ui_strings.py:10
msgid "Regular expression mode"
msgstr "Modalità espressione regolare"

#: src/pbrenamer/ui/pattern_help.py:175 /tmp/_pbrenamer_ui_strings.py:12
msgid "Plain text mode"
msgstr "Modalità testo normale"

#: src/pbrenamer/ui/pattern_help.py:186
#, python-brace-format
msgid ""
"The replacement string is the same regardless of the search mode. Fields are "
"written <code>{name}</code> and may include formatting options:"
msgstr ""
"La stringa di sostituzione è la stessa indipendentemente dalla modalità di "
"ricerca. I campi si scrivono <code>{name}</code> e possono includere opzioni "
"di formattazione:"

#: src/pbrenamer/ui/pattern_help.py:191
msgid "plain value"
msgstr "valore semplice"

#: src/pbrenamer/ui/pattern_help.py:192
msgid "with format"
msgstr "con formato"

#: src/pbrenamer/ui/pattern_help.py:193
msgid "with format and fallback"
msgstr "con formato e valore alternativo"

#: src/pbrenamer/ui/pattern_help.py:194
msgid "left-align  (digit fmt = min width)"
msgstr "allineamento a sinistra  (fmt cifra = larghezza minima)"

#: src/pbrenamer/ui/pattern_help.py:195
msgid "right-align"
msgstr "allineamento a destra"

#: src/pbrenamer/ui/pattern_help.py:196
msgid "zero-pad right (numbers)"
msgstr "riempimento con zeri a destra (numeri)"

#: src/pbrenamer/ui/pattern_help.py:197
msgid "literal '{' character"
msgstr "carattere '{' letterale"

#: src/pbrenamer/ui/pattern_help.py:201
msgid ""
"<b>fmt</b> is a minimum width (digit) for text/numbers, or a <code>strftime</"
"code> format for dates/datetimes.<br><b>default</b>: used when the field is "
"absent; omitting it makes absence an error (file shown in red in the "
"preview)."
msgstr ""
"<b>fmt</b> è una larghezza minima (cifra) per testo/numeri, o un formato "
"<code>strftime</code> per date/orari.<br><b>default</b>: usato quando il "
"campo è assente; ometterlo rende l'assenza un errore (il file viene mostrato "
"in rosso nell'anteprima)."

#: src/pbrenamer/ui/pattern_help.py:208
msgid "all modes"
msgstr "tutte le modalità"

#: src/pbrenamer/ui/pattern_help.py:209
msgid "pattern, regex"
msgstr "pattern, regex"

#: src/pbrenamer/ui/pattern_help.py:210
msgid "regex only"
msgstr "solo regex"

#: src/pbrenamer/ui/pattern_help.py:211
msgid "Field"
msgstr "Campo"

#: src/pbrenamer/ui/pattern_help.py:212
msgid "Available in"
msgstr "Disponibile in"

#: src/pbrenamer/ui/pattern_help.py:213
msgid "Description"
msgstr "Descrizione"

#: src/pbrenamer/ui/pattern_help.py:224
msgid "Full matched text (or search literal in plain-text mode)"
msgstr "Testo corrispondente completo (o letterale di ricerca in modalità testo)"

#: src/pbrenamer/ui/pattern_help.py:230
msgid "Numbered capture groups (1-based)"
msgstr "Gruppi di cattura numerati (a partire da 1)"

#: src/pbrenamer/ui/pattern_help.py:235
msgid "Named group <code>(?P&lt;name&gt;…)</code> from the search regex"
msgstr "Gruppo denominato <code>(?P&lt;name&gt;…)</code> dalla regex di ricerca"

#: src/pbrenamer/ui/pattern_help.py:242
msgid ""
"Auto-incrementing counter — default fmt is a minimum width; <em>default</em> "
"sets the start value (e.g. <code>{num:02:10}</code> starts at 10, zero-"
"padded to 2 digits)"
msgstr ""
"Contatore a incremento automatico — il fmt predefinito è una larghezza "
"minima; <em>default</em> imposta il valore iniziale (es. "
"<code>{num:02:10}</code> parte da 10, con zero a 2 cifre)"

#: src/pbrenamer/ui/pattern_help.py:251
#, python-brace-format
msgid ""
"Like <code>{num}</code> but skips values whose target name already exists on "
"disk or has been assigned to another file in the same batch — guarantees no "
"conflicts"
msgstr ""
"Come <code>{num}</code> ma salta i valori il cui nome di destinazione esiste "
"già su disco o è stato assegnato a un altro file dello stesso lotto — "
"garantisce assenza di conflitti"

#: src/pbrenamer/ui/pattern_help.py:260
msgid "Today's date — default fmt <code>%Y-%m-%d</code>"
msgstr "Data odierna — formato predefinito <code>%Y-%m-%d</code>"

#: src/pbrenamer/ui/pattern_help.py:266
msgid "Current date and time — default fmt <code>%Y-%m-%d_%H%M%S</code>"
msgstr "Data e ora correnti — formato predefinito <code>%Y-%m-%d_%H%M%S</code>"

#: src/pbrenamer/ui/pattern_help.py:271
msgid "File modification date/time — default fmt <code>%Y-%m-%d_%H%M%S</code>"
msgstr ""
"Data/ora di modifica del file — formato predefinito "
"<code>%Y-%m-%d_%H%M%S</code>"

#: src/pbrenamer/ui/pattern_help.py:278
msgid ""
"File creation date/time — default fmt <code>%Y-%m-%d_%H%M%S</code> (inode "
"change time on Linux)"
msgstr ""
"Data/ora di creazione del file — formato predefinito "
"<code>%Y-%m-%d_%H%M%S</code> (tempo di modifica inode su Linux)"

#: src/pbrenamer/ui/pattern_help.py:282
msgid "Name of the immediate parent folder"
msgstr "Nome della cartella padre immediata"

#: src/pbrenamer/ui/pattern_help.py:286
msgid "EXIF or IPTC metadata field (images only — see list below)"
msgstr "Campo metadati EXIF o IPTC (solo immagini — vedi lista sotto)"

#: src/pbrenamer/ui/pattern_help.py:291
msgid "Audio metadata field (mp3, ogg, flac… — see list below)"
msgstr "Campo metadati audio (mp3, ogg, flac… — vedi lista sotto)"

#: src/pbrenamer/ui/pattern_help.py:297
msgid "Video metadata field (mp4, mkv, avi… — see list below)"
msgstr "Campo metadati video (mp4, mkv, avi… — vedi lista sotto)"

#: src/pbrenamer/ui/pattern_help.py:303
msgid ""
"Field names are case-insensitive. A <b>default</b> is strongly recommended "
"for metadata fields — they may be absent from non-image files or images "
"without metadata."
msgstr ""
"I nomi dei campi non fanno distinzione tra maiuscole e minuscole. Un valore "
"<b>default</b> è fortemente raccomandato per i campi metadati — possono "
"essere assenti in file non-immagine o immagini senza metadati."

#: src/pbrenamer/ui/pattern_help.py:307
msgid "Type"
msgstr "Tipo"

#: src/pbrenamer/ui/pattern_help.py:314
msgid "Date/time the photo was taken"
msgstr "Data/ora in cui è stata scattata la foto"

#: src/pbrenamer/ui/pattern_help.py:315
msgid "Date/time the image was digitised"
msgstr "Data/ora di digitalizzazione dell'immagine"

#: src/pbrenamer/ui/pattern_help.py:319
msgid "Date/time the file was last changed (EXIF)"
msgstr "Data/ora dell'ultima modifica del file (EXIF)"

#: src/pbrenamer/ui/pattern_help.py:322
msgid "Camera manufacturer"
msgstr "Produttore della fotocamera"

#: src/pbrenamer/ui/pattern_help.py:323
msgid "Camera model"
msgstr "Modello fotocamera"

#: src/pbrenamer/ui/pattern_help.py:324
msgid "Lens model"
msgstr "Modello obiettivo"

#: src/pbrenamer/ui/pattern_help.py:325
msgid "ISO speed"
msgstr "Sensibilità ISO"

#: src/pbrenamer/ui/pattern_help.py:326
msgid "Aperture (e.g. 2.8)"
msgstr "Apertura (es. 2.8)"

#: src/pbrenamer/ui/pattern_help.py:327
msgid "Shutter speed (e.g. 1/125)"
msgstr "Velocità dell'otturatore (es. 1/125)"

#: src/pbrenamer/ui/pattern_help.py:328
msgid "Focal length in mm"
msgstr "Lunghezza focale in mm"

#: src/pbrenamer/ui/pattern_help.py:329
msgid "Image description / title"
msgstr "Descrizione / titolo dell'immagine"

#: src/pbrenamer/ui/pattern_help.py:330
msgid "Photographer / creator (EXIF)"
msgstr "Fotografo / autore (EXIF)"

#: src/pbrenamer/ui/pattern_help.py:331
msgid "Copyright notice"
msgstr "Avviso di copyright"

#: src/pbrenamer/ui/pattern_help.py:332
msgid "IPTC title / object name"
msgstr "Titolo IPTC / nome oggetto"

#: src/pbrenamer/ui/pattern_help.py:333
msgid "IPTC photographer / creator"
msgstr "Fotografo IPTC / autore"

#: src/pbrenamer/ui/pattern_help.py:334
msgid "IPTC city"
msgstr "Città IPTC"

#: src/pbrenamer/ui/pattern_help.py:335
msgid "IPTC country"
msgstr "Paese IPTC"

#: src/pbrenamer/ui/pattern_help.py:336
msgid "IPTC creation date"
msgstr "Data di creazione IPTC"

#: src/pbrenamer/ui/pattern_help.py:337
msgid "IPTC keywords (semicolon-separated)"
msgstr "Parole chiave IPTC (separate da punto e virgola)"

#: src/pbrenamer/ui/pattern_help.py:342
msgid ""
"Field names are case-insensitive. Supported formats: mp3, ogg, flac, opus, "
"aac/m4a and others supported by mutagen. A <b>default</b> is strongly "
"recommended — tags may be absent or the file may not be a supported audio "
"format."
msgstr ""
"I nomi dei campi non fanno distinzione tra maiuscole e minuscole. Formati "
"supportati: mp3, ogg, flac, opus, aac/m4a e altri supportati da mutagen. Un "
"valore <b>default</b> è fortemente raccomandato — i tag potrebbero essere "
"assenti o il file potrebbe non essere un formato audio supportato."

#: src/pbrenamer/ui/pattern_help.py:349
msgid "Track title"
msgstr "Titolo della traccia"

#: src/pbrenamer/ui/pattern_help.py:350
msgid "Track artist"
msgstr "Artista della traccia"

#: src/pbrenamer/ui/pattern_help.py:351
msgid "Album artist"
msgstr "Artista dell'album"

#: src/pbrenamer/ui/pattern_help.py:352
msgid "Album name"
msgstr "Nome dell'album"

#: src/pbrenamer/ui/pattern_help.py:354
msgid "Track number (strips /total if present)"
msgstr "Numero della traccia (rimuove /totale se presente)"

#: src/pbrenamer/ui/pattern_help.py:356
msgid "Disc number (strips /total if present)"
msgstr "Numero del disco (rimuove /totale se presente)"

#: src/pbrenamer/ui/pattern_help.py:361
msgid ""
"Release date — datetime.date when full date available (strftime formatting); "
"plain text otherwise"
msgstr ""
"Data di pubblicazione — datetime.date quando la data completa è disponibile "
"(formattazione strftime); testo normale altrimenti"

#: src/pbrenamer/ui/pattern_help.py:366
msgid "Release year (extracted from date tag)"
msgstr "Anno di pubblicazione (estratto dal tag data)"

#: src/pbrenamer/ui/pattern_help.py:367
msgid "Genre"
msgstr "Genere"

#: src/pbrenamer/ui/pattern_help.py:368
msgid "Comment"
msgstr "Commento"

#: src/pbrenamer/ui/pattern_help.py:369
msgid "Composer"
msgstr "Compositore"

#: src/pbrenamer/ui/pattern_help.py:370
msgid "Beats per minute"
msgstr "Battiti al minuto"

#: src/pbrenamer/ui/pattern_help.py:371 src/pbrenamer/ui/pattern_help.py:386
msgid "Duration in seconds"
msgstr "Durata in secondi"

#: src/pbrenamer/ui/pattern_help.py:372
msgid "Bitrate in kbps"
msgstr "Bitrate in kbps"

#: src/pbrenamer/ui/pattern_help.py:377
msgid ""
"Field names are case-insensitive. Supported formats: mp4, mkv, avi, mov, "
"webm and others supported by MediaInfo (pymediainfo). A <b>default</b> is "
"strongly recommended — fields may be absent or the file may not be a "
"supported video format."
msgstr ""
"I nomi dei campi non fanno distinzione tra maiuscole e minuscole. Formati "
"supportati: mp4, mkv, avi, mov, webm e altri supportati da MediaInfo "
"(pymediainfo). Un valore <b>default</b> è fortemente raccomandato — i campi "
"potrebbero essere assenti o il file potrebbe non essere un formato video "
"supportato."

#: src/pbrenamer/ui/pattern_help.py:384
msgid "Video width in pixels"
msgstr "Larghezza video in pixel"

#: src/pbrenamer/ui/pattern_help.py:385
msgid "Video height in pixels"
msgstr "Altezza video in pixel"

#: src/pbrenamer/ui/pattern_help.py:387
msgid "Frame rate (e.g. 29.970)"
msgstr "Frame rate (es. 29.970)"

#: src/pbrenamer/ui/pattern_help.py:388
msgid "Video codec name (e.g. AVC, HEVC)"
msgstr "Nome del codec video (es. AVC, HEVC)"

#: src/pbrenamer/ui/pattern_help.py:389
msgid "Audio codec name (e.g. AAC, AC-3)"
msgstr "Nome del codec audio (es. AAC, AC-3)"

#: src/pbrenamer/ui/pattern_help.py:390
msgid "Number of audio channels"
msgstr "Numero di canali audio"

#: src/pbrenamer/ui/pattern_help.py:391
msgid "Overall bitrate in kbps"
msgstr "Bitrate globale in kbps"

#: src/pbrenamer/ui/pattern_help.py:392
msgid "Title tag"
msgstr "Tag titolo"

#: src/pbrenamer/ui/pattern_help.py:393
msgid "Encoded date/time"
msgstr "Data/ora di codifica"

#: src/pbrenamer/ui/pattern_help.py:401
msgid "Capture group 1 followed by a 4-digit zero-padded counter (starts at 1)"
msgstr ""
"Gruppo di cattura 1 seguito da un contatore a 4 cifre con zeri iniziali "
"(parte da 1)"

#: src/pbrenamer/ui/pattern_help.py:406
msgid "Same, but counter starts at 10"
msgstr "Come sopra, ma il contatore parte da 10"

#: src/pbrenamer/ui/pattern_help.py:410
msgid ""
"Conflict-free 3-digit counter: skips values where <code>backup_NNN</code> "
"already exists"
msgstr ""
"Contatore a 3 cifre senza conflitti: salta i valori dove "
"<code>backup_NNN</code> esiste già"

#: src/pbrenamer/ui/pattern_help.py:415
msgid "Today's date prepended to the matched text"
msgstr "Data odierna anteposta al testo corrispondente"

#: src/pbrenamer/ui/pattern_help.py:418
msgid "Shooting date/time compact; \"unknown\" if EXIF absent"
msgstr "Data/ora di scatto compatta; \"sconosciuto\" se EXIF assente"

#: src/pbrenamer/ui/pattern_help.py:423
msgid "Hour+minute of digitisation; \"0000\" if absent"
msgstr "Ora+minuto di digitalizzazione; \"0000\" se assente"

#: src/pbrenamer/ui/pattern_help.py:427
msgid "Camera make and model (empty string if absent)"
msgstr "Marca e modello fotocamera (stringa vuota se assente)"

#: src/pbrenamer/ui/pattern_help.py:432
msgid "Audio artist and title; \"unknown\"/\"untitled\" if absent"
msgstr "Artista e titolo audio; \"sconosciuto\"/\"senza titolo\" se assente"

#: src/pbrenamer/ui/pattern_help.py:436
msgid "Audio release date, zero-padded track number, title"
msgstr "Data di pubblicazione audio, numero traccia con zeri, titolo"

#: src/pbrenamer/ui/pattern_help.py:441
msgid "Video resolution and codec (e.g. 1920x1080_AVC)"
msgstr "Risoluzione e codec video (es. 1920x1080_AVC)"

#: src/pbrenamer/ui/pattern_help.py:445
msgid "Video encoded date and duration in seconds"
msgstr "Data di codifica video e durata in secondi"

#: src/pbrenamer/ui/pattern_help.py:448
msgid "Named regex groups (regex mode only)"
msgstr "Gruppi regex denominati (solo modalità regex)"

#: src/pbrenamer/ui/pattern_help.py:451
msgid "Parent folder, file modification date, 3-digit counter"
msgstr "Cartella padre, data di modifica del file, contatore a 3 cifre"

#: src/pbrenamer/ui/pattern_help.py:458
msgid "Replacement fields"
msgstr "Campi di sostituzione"

#: src/pbrenamer/ui/pattern_help.py:463
msgid "Available fields"
msgstr "Campi disponibili"

#: src/pbrenamer/ui/pattern_help.py:469
msgid "Metadata fields for <code>{im:…}</code>"
msgstr "Campi metadati per <code>{im:…}</code>"

#: src/pbrenamer/ui/pattern_help.py:476
msgid "Audio metadata fields for <code>{au:…}</code>"
msgstr "Campi metadati audio per <code>{au:…}</code>"

#: src/pbrenamer/ui/pattern_help.py:483
msgid "Video metadata fields for <code>{vi:…}</code>"
msgstr "Campi metadati video per <code>{vi:…}</code>"

#: src/pbrenamer/ui/pattern_help.py:490
msgid "Examples"
msgstr "Esempi"

#: src/pbrenamer/ui/main_window.py:202
msgid "Select folder"
msgstr "Seleziona cartella"

#: src/pbrenamer/ui/main_window.py:245 /tmp/_pbrenamer_ui_strings.py:86
msgid "Original"
msgstr "Originale"

#: src/pbrenamer/ui/main_window.py:245 /tmp/_pbrenamer_ui_strings.py:85
#: /tmp/_pbrenamer_ui_strings.py:146
msgid "Preview"
msgstr "Anteprima"

#: src/pbrenamer/ui/main_window.py:258
#, python-brace-format
msgid "{path} — {n} item(s)"
msgstr "{path} — {n} elemento/i"

#: src/pbrenamer/ui/main_window.py:530
#, python-brace-format
msgid "⚠ {field} unavailable"
msgstr "⚠ {field} non disponibile"

#: src/pbrenamer/ui/main_window.py:610
msgid "Search — Help"
msgstr "Ricerca — Guida"

#: src/pbrenamer/ui/main_window.py:625
msgid "Replace — Help"
msgstr "Sostituzione — Guida"

#: src/pbrenamer/ui/main_window.py:811
msgid "Rename errors"
msgstr "Errori di rinomina"

#: src/pbrenamer/i18n.py:65 /tmp/_pbrenamer_ui_strings.py:161
msgid "language_name"
msgstr "Italiano"

#: /tmp/_pbrenamer_ui_strings.py:1
msgid "History"
msgstr "Cronologia"

#: /tmp/_pbrenamer_ui_strings.py:2
msgid "Search"
msgstr "Ricerca"

#: /tmp/_pbrenamer_ui_strings.py:3
msgid "Search pattern history"
msgstr "Cronologia dei pattern di ricerca"

#: /tmp/_pbrenamer_ui_strings.py:4 /tmp/_pbrenamer_ui_strings.py:23
msgid "Select one or more entries to remove them"
msgstr "Seleziona una o più voci per rimuoverle"

#: /tmp/_pbrenamer_ui_strings.py:5 /tmp/_pbrenamer_ui_strings.py:24
msgid "Pattern…"
msgstr "Pattern…"

#: /tmp/_pbrenamer_ui_strings.py:6
msgid "New search pattern to add"
msgstr "Nuovo pattern di ricerca da aggiungere"

#: /tmp/_pbrenamer_ui_strings.py:7
msgid "pat"
msgstr "pat"

#: /tmp/_pbrenamer_ui_strings.py:8
msgid "Pattern token mode"
msgstr "Modalità token pattern"

#: /tmp/_pbrenamer_ui_strings.py:9
msgid "RE"
msgstr "RE"

#: /tmp/_pbrenamer_ui_strings.py:11
