# ==AUTO== Automatically translated
#: src/pbrenamer/ui/pattern_help.py:105
msgid ""
"Full Python <code>re</code>-module syntax. The match is applied to the "
"file stem (or full name if <em>Keep extension</em> is unchecked)."
msgstr ""
"Sintassi completa del modulo <code>re</code> di Python. La corrispondenza"
" viene applicata al nome base del file (o al nome completo se "
"<em>Mantieni estensione</em> è deselezionato).Sintassi completa del "
"modulo Python <code>re</code>. La corrispondenza viene applicata al nome "
"base del file (o al nome completo se <em>Mantieni estensione</em> è "
"deselezionato)."

#: src/pbrenamer/ui/pattern_help.py:110
msgid "Any single character"
msgstr "Qualsiasi singolo carattere"

#: src/pbrenamer/ui/pattern_help.py:112
msgid "Any sequence (greedy), non-empty variant"
msgstr "Qualsiasi sequenza (greedy), variante non vuota"

#: src/pbrenamer/ui/pattern_help.py:114
msgid "One or more digits"
msgstr "Una o più cifre"

#: src/pbrenamer/ui/pattern_help.py:115
