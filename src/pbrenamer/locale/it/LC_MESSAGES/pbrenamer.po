#: src/pbrenamer/ui/pattern_help.py:209
msgid "Available in"
msgstr "Disponibile in"

#: src/pbrenamer/ui/file_info_window.py:71 src/pbrenamer/ui/pattern_help.py:210
msgid "Description"
msgstr "Descrizione"

#: src/pbrenamer/ui/pattern_help.py:221
msgid "Full matched text (or search literal in plain-text mode)"
msgstr "Testo corrispondente completo (o letterale di ricerca in modalità testo)"

#: src/pbrenamer/ui/pattern_help.py:227
msgid "Numbered capture groups (1-based)"
msgstr "Gruppi di cattura numerati (a partire da 1)"

#: src/pbrenamer/ui/pattern_help.py:232
msgid "Named group <code>(?P&lt;name&gt;…)</code> from the search regex"
msgstr "Gruppo denominato <code>(?P&lt;name&gt;…)</code> dalla regex di ricerca"

# ==AUTO== Automatically translated
#: src/pbrenamer/ui/pattern_help.py:239
#, python-brace-format
msgid ""
"Auto-incrementing counter — default fmt is a minimum width; "
"<em>default</em> sets the start value (e.g. <code>{num:02:10}</code> "
"starts at 10, zero-padded to 2 digits)"
msgstr ""
"Contatore autoincrementante — fmt è una larghezza minima; "
"<em>default</em> imposta il valore iniziale (es. <code>{num:02:10}</code>"
" inizia da 10, riempito a 2 cifre con zeri)Contatore a incremento "
"automatico — il fmt predefinito è una larghezza minima; <em>default</em> "
"imposta il valore iniziale (es. <code>{num:02:10}</code> parte da 10, con"
" zero a 2 cifre)"

# ==AUTO== Automatically translated
#: src/pbrenamer/ui/pattern_help.py:248
#, python-brace-format
msgid ""
"Like <code>{num}</code> but skips values whose target name already exists"
" on disk or has been assigned to another file in the same batch — "
"guarantees no conflicts"
msgstr ""
"Come <code>{num}</code> ma salta i valori il cui nome destinazione esiste"
" già su disco o è stato assegnato a un altro file dello stesso batch — "
"garantisce nessun conflittoCome <code>{num}</code> ma salta i valori il "
"cui nome di destinazione esiste già su disco o è stato assegnato a un "
"altro file dello stesso lotto — garantisce assenza di conflitti"

