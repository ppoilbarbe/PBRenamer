msgid "language_name"
msgstr "Italiano"

#: tools/_ui_strings_tmp.py:1
msgid "History"
msgstr "Cronologia"

#: tools/_ui_strings_tmp.py:2
msgid "Search"
msgstr "Ricerca"

#: tools/_ui_strings_tmp.py:3
msgid "Search pattern history"
msgstr "Cronologia dei pattern di ricerca"

#: tools/_ui_strings_tmp.py:4 tools/_ui_strings_tmp.py:23
msgid "Select one or more entries to remove them"
msgstr "Seleziona una o più voci per rimuoverle"

#: tools/_ui_strings_tmp.py:5 tools/_ui_strings_tmp.py:24
msgid "Pattern…"
msgstr "Pattern…"

#: tools/_ui_strings_tmp.py:6
msgid "New search pattern to add"
msgstr "Nuovo pattern di ricerca da aggiungere"

#: tools/_ui_strings_tmp.py:7
msgid "pat"
msgstr "pat"

