msgstr ""
"Compteur à 3 chiffres sans conflit : saute les valeurs où "
"<code>backup_NNN</code> existe déjàCompteur 3 chiffres sans conflit : "
"saute les valeurs où <code>backup_NNN</code> existe déjà"

#: src/pbrenamer/ui/pattern_help.py:412
msgid "Today's date prepended to the matched text"
msgstr "Date du jour préfixée au texte correspondant"

#: src/pbrenamer/ui/pattern_help.py:415
msgid "Shooting date/time compact; \"unknown\" if EXIF absent"
msgstr "Date/heure de prise de vue compact ; \"inconnu\" si EXIF absent"

#: src/pbrenamer/ui/pattern_help.py:420
msgid "Hour+minute of digitisation; \"0000\" if absent"
msgstr "Heure+minute de numérisation ; \"0000\" si absent"

#: src/pbrenamer/ui/pattern_help.py:424
