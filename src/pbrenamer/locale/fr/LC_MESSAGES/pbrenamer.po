#: src/pbrenamer/ui/pattern_help.py:73
#, python-brace-format
msgid ""
"Tokens act as typed wildcards. Segments enclosed in <b>{1}</b>, "
"<b>{2}</b>… are <em>captured</em> and available for reuse in the "
"replacement field."
msgstr ""
"Les jetons agissent comme des jokers. Les segments délimités par "
"<b>{1}</b>, <b>{2}</b>… sont <em>capturés</em> et disponibles dans le "
"champ de remplacement.Les jetons agissent comme des jokers typés. Les "
"segments entre <b>{1}</b>, <b>{2}</b>… sont <em>capturés</em> et "
"réutilisables dans le champ de remplacement."

#: src/pbrenamer/ui/pattern_help.py:78
msgid "One or more digits (0–9)"
msgstr "Un ou plusieurs chiffres (0–9)"

#: src/pbrenamer/ui/pattern_help.py:79
msgid "One or more letters (a–z, A–Z and Unicode letters)"
msgstr "Une ou plusieurs lettres (a–z, A–Z et lettres Unicode)"

#: src/pbrenamer/ui/pattern_help.py:80
msgid "One or more non-whitespace characters"
msgstr "Un ou plusieurs caractères non-blancs"

#: src/pbrenamer/ui/pattern_help.py:81
msgid "Any sequence of characters, including empty"
msgstr "Toute séquence de caractères, y compris vide"

#: src/pbrenamer/ui/pattern_help.py:82
msgid "Trash — matches and discards a segment (not captured)"
msgstr "Poubelle — correspond à un segment et le rejette (non capturé)"

#: src/pbrenamer/ui/pattern_help.py:86
#, python-brace-format
msgid "Capture group — the matched text is bound to {1}, {2}… in the replacement"
msgstr ""
"Groupe capturant — le texte correspondant est associé à {1}, {2}… dans le"
" remplacementGroupe capturant — le texte correspondant est lié à {1}, "
"{2}… dans le remplacement"

#: src/pbrenamer/ui/pattern_help.py:94 src/pbrenamer/ui/pattern_help.py:134
#: src/pbrenamer/ui/pattern_help.py:150
msgid "Example"
msgstr "Exemple"

#: src/pbrenamer/ui/pattern_help.py:96 src/pbrenamer/ui/pattern_help.py:136
#: src/pbrenamer/ui/pattern_help.py:152 tools/_ui_strings_tmp.py:84
msgid "Search:"
msgstr "Recherche :"

#: src/pbrenamer/ui/pattern_help.py:98 src/pbrenamer/ui/pattern_help.py:138
#: src/pbrenamer/ui/pattern_help.py:154 tools/_ui_strings_tmp.py:103
msgid "Replace:"
msgstr "Remplacement :"

#: src/pbrenamer/ui/pattern_help.py:105
msgid ""
"Full Python <code>re</code>-module syntax. The match is applied to the "
"file stem (or full name if <em>Keep extension</em> is unchecked)."
msgstr ""
"Syntaxe Python complète du module <code>re</code>. La correspondance est "
"appliquée au nom de fichier sans extension (ou au nom complet si "
"<em>Conserver l'extension</em> est décoché).Syntaxe complète du module "
"Python <code>re</code>. La correspondance porte sur le radical du fichier"
" (ou le nom entier si <em>Garder l'extension</em> est décoché)."

#: src/pbrenamer/ui/pattern_help.py:110
msgid "Any single character"
msgstr "N'importe quel caractère"

#: src/pbrenamer/ui/pattern_help.py:112
msgid "Any sequence (greedy), non-empty variant"
msgstr "Toute séquence (gourmand), variante non vide"

#: src/pbrenamer/ui/pattern_help.py:114
msgid "One or more digits"
msgstr "Un ou plusieurs chiffres"

#: src/pbrenamer/ui/pattern_help.py:115
msgid "Word characters (letters, digits, _)"
msgstr "Caractères de mot (lettres, chiffres, _)"

#: src/pbrenamer/ui/pattern_help.py:119
msgid ""
"Numbered capture group → <code>\\1</code>, <code>\\2</code>… in "
"replacement"
msgstr ""
"Groupe capturant numéroté → <code>\\1</code>, <code>\\2</code>… dans le "
"remplacement"

#: src/pbrenamer/ui/pattern_help.py:126
msgid "Named capture group → <code>\\g&lt;name&gt;</code> in replacement"
msgstr "Groupe capturant nommé → <code>\\g&lt;name&gt;</code> dans le remplacement"

#: src/pbrenamer/ui/pattern_help.py:128
msgid "Case-insensitive flag"
msgstr "Indicateur insensible à la casse"

#: src/pbrenamer/ui/pattern_help.py:129
msgid "Start / end of the name"
msgstr "Début / fin du nom"

#: src/pbrenamer/ui/pattern_help.py:145
msgid ""
"The search field is matched as a literal string — no wildcards, no "
"special characters. Every occurrence of the exact text in the file name "
"is replaced."
msgstr ""
"Le champ de recherche est mis en correspondance comme une chaîne "
"littérale — pas de jokers, pas de caractères spéciaux. Chaque occurrence "
"du texte exact dans le nom de fichier est remplacée.Le champ de recherche"
" est comparé en tant que chaîne littérale — pas de jokers, pas de "
"caractères spéciaux. Toutes les occurrences du texte exact dans le nom de"
" fichier sont remplacées."

#: src/pbrenamer/ui/pattern_help.py:161
msgid "Search patterns"
msgstr "Motifs de recherche"

#: src/pbrenamer/ui/pattern_help.py:162
msgid "Pattern mode"
msgstr "Mode motif"

#: src/pbrenamer/ui/pattern_help.py:167 tools/_ui_strings_tmp.py:10
msgid "Regular expression mode"
msgstr "Mode expression rationnelle"

#: src/pbrenamer/ui/pattern_help.py:172 tools/_ui_strings_tmp.py:12
msgid "Plain text mode"
msgstr "Mode texte brut"

#: src/pbrenamer/ui/pattern_help.py:183
#, python-brace-format
msgid ""
"The replacement string is the same regardless of the search mode. Fields "
"are written <code>{name}</code> and may include formatting options:"
msgstr ""
"La chaîne de remplacement est identique quel que soit le mode de "
"recherche. Les champs s'écrivent <code>{name}</code> et peuvent inclure "
"des options de formatage :"

#: src/pbrenamer/ui/pattern_help.py:188
msgid "plain value"
msgstr "valeur brute"

#: src/pbrenamer/ui/pattern_help.py:189
msgid "with format"
msgstr "avec format"

#: src/pbrenamer/ui/pattern_help.py:190
msgid "with format and fallback"
msgstr "avec format et valeur de repli"

#: src/pbrenamer/ui/pattern_help.py:191
msgid "left-align  (digit fmt = min width)"
msgstr "aligner à gauche  (fmt chiffre = largeur min)"

#: src/pbrenamer/ui/pattern_help.py:192
msgid "right-align"
msgstr "aligner à droite"

#: src/pbrenamer/ui/pattern_help.py:193
msgid "zero-pad right (numbers)"
msgstr "compléter par des zéros à droite (nombres)"

#: src/pbrenamer/ui/pattern_help.py:194
msgid "literal '{' character"
msgstr "caractère '{' littéral"

#: src/pbrenamer/ui/pattern_help.py:198
msgid ""
"<b>fmt</b> is a minimum width (digit) for text/numbers, or a "
"<code>strftime</code> format for dates/datetimes.<br><b>default</b>: used"
" when the field is absent; omitting it makes absence an error (file shown"
" in red in the preview)."
msgstr ""
"<b>fmt</b> est une largeur minimale (chiffre) pour les textes/nombres, ou"
" un format <code>strftime</code> pour les "
"dates/horodatages.<br><b>default</b> : utilisé si le champ est absent ; "
"l'omettre rend l'absence une erreur (fichier en rouge dans "
"l'aperçu).<b>fmt</b> est une largeur minimale (chiffre) pour les "
"textes/nombres, ou un format <code>strftime</code> pour les "
"dates/heures.<br><b>default</b> : utilisé quand le champ est absent ; "
"l'omettre rend l'absence erreur (fichier affiché en rouge dans l'aperçu)."

#: src/pbrenamer/ui/pattern_help.py:205
msgid "all modes"
msgstr "tous modes"

#: src/pbrenamer/ui/pattern_help.py:206
msgid "pattern, regex"
msgstr "motif, regex"

#: src/pbrenamer/ui/pattern_help.py:207
msgid "regex only"
msgstr "regex uniquement"

#: src/pbrenamer/ui/file_info_window.py:71 src/pbrenamer/ui/pattern_help.py:208
msgid "Field"
msgstr "Champ"

#: src/pbrenamer/ui/pattern_help.py:209
msgid "Available in"
msgstr "Disponible en"

#: src/pbrenamer/ui/file_info_window.py:71 src/pbrenamer/ui/pattern_help.py:210
msgid "Description"
msgstr "Description"

#: src/pbrenamer/ui/pattern_help.py:221
msgid "Full matched text (or search literal in plain-text mode)"
msgstr "Texte intégral correspondant (ou littéral de recherche en mode texte brut)"

#: src/pbrenamer/ui/pattern_help.py:227
msgid "Numbered capture groups (1-based)"
msgstr "Groupes capturants numérotés (à partir de 1)"

#: src/pbrenamer/ui/pattern_help.py:232
msgid "Named group <code>(?P&lt;name&gt;…)</code> from the search regex"
msgstr "Groupe nommé <code>(?P&lt;name&gt;…)</code> issu de la regex de recherche"

#: src/pbrenamer/ui/pattern_help.py:239
#, python-brace-format
msgid ""
"Auto-incrementing counter — default fmt is a minimum width; "
"<em>default</em> sets the start value (e.g. <code>{num:02:10}</code> "
"starts at 10, zero-padded to 2 digits)"
msgstr ""
"Compteur auto-incrémenté — fmt est une largeur minimale ; "
"<em>default</em> fixe la valeur de départ (ex. <code>{num:02:10}</code> "
"démarre à 10, complété à 2 chiffres)Compteur auto-incrémenté — fmt par "
"défaut est une largeur min ; <em>default</em> fixe la valeur de départ "
"(ex. <code>{num:02:10}</code> démarre à 10, complété à 2 chiffres)"

#: src/pbrenamer/ui/pattern_help.py:248
#, python-brace-format
msgid ""
"Like <code>{num}</code> but skips values whose target name already exists"
" on disk or has been assigned to another file in the same batch — "
"guarantees no conflicts"
msgstr ""
"Comme <code>{num}</code> mais saute les valeurs dont le nom cible existe "
"déjà sur le disque ou a été attribué à un autre fichier du même lot — "
"garantit l'absence de conflitsComme <code>{num}</code> mais saute les "
"valeurs dont le nom cible existe déjà sur disque ou a été attribué à un "
"autre fichier du lot — garantit l'absence de conflits"

#: src/pbrenamer/ui/pattern_help.py:257
#, python-format
msgid "Today's date — default fmt <code>%Y-%m-%d</code>"
msgstr "Date du jour — format par défaut <code>%Y-%m-%d</code>"

#: src/pbrenamer/ui/pattern_help.py:263
#, python-format
msgid "Current date and time — default fmt <code>%Y-%m-%d_%H%M%S</code>"
msgstr "Date et heure courantes — format par défaut <code>%Y-%m-%d_%H%M%S</code>"

#: src/pbrenamer/ui/pattern_help.py:268
#, python-format
msgid "File modification date/time — default fmt <code>%Y-%m-%d_%H%M%S</code>"
msgstr "Date/heure de modification — fmt par défaut <code>%Y-%m-%d_%H%M%S</code>"

#: src/pbrenamer/ui/pattern_help.py:275
#, python-format
msgid ""
"File creation date/time — default fmt <code>%Y-%m-%d_%H%M%S</code> (inode"
" change time on Linux)"
msgstr ""
"Date/heure de création — fmt par défaut <code>%Y-%m-%d_%H%M%S</code> "
"(date de changement d'inode sous Linux)"

#: src/pbrenamer/ui/pattern_help.py:279
msgid "Name of the immediate parent folder"
msgstr "Nom du dossier parent immédiat"

#: src/pbrenamer/ui/pattern_help.py:283
msgid "EXIF or IPTC metadata field (images only — see list below)"
msgstr ""
"Champ de métadonnées EXIF ou IPTC (images uniquement — voir la liste ci-"
"dessous)Champ de métadonnées EXIF ou IPTC (images uniquement — voir liste"
" ci-dessous)"

#: src/pbrenamer/ui/pattern_help.py:288
msgid "Audio metadata field (mp3, ogg, flac… — see list below)"
msgstr "Champ de métadonnées audio (mp3, ogg, flac… — voir liste ci-dessous)"

#: src/pbrenamer/ui/pattern_help.py:294
msgid "Video metadata field (mp4, mkv, avi… — see list below)"
msgstr "Champ de métadonnées vidéo (mp4, mkv, avi… — voir liste ci-dessous)"

#: src/pbrenamer/ui/pattern_help.py:300
msgid ""
"Field names are case-insensitive. A <b>default</b> is strongly "
"recommended for metadata fields — they may be absent from non-image files"
" or images without metadata."
msgstr ""
"Les noms de champs ne sont pas sensibles à la casse. Un <b>default</b> "
"est fortement recommandé pour les champs de métadonnées — ils peuvent "
"être absents des fichiers non-image ou des images sans métadonnées.Les "
"noms de champs sont insensibles à la casse. Une valeur <b>default</b> est"
" fortement recommandée pour les champs de métadonnées — ils peuvent être "
"absents des fichiers non-image ou des images sans métadonnées."

