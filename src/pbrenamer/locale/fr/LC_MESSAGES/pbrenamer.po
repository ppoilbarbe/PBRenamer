#: src/pbrenamer/ui/settings_dialog.py:22
msgid "Settings"
msgstr "Préférences"

#: src/pbrenamer/ui/settings_dialog.py:26
msgid "System default"
msgstr "Langue du système"

#: src/pbrenamer/ui/settings_dialog.py:43
msgid "A restart is required for the language change to take effect."
msgstr ""
"Un redémarrage est nécessaire pour que le changement de langue prenne effet."

#: src/pbrenamer/ui/settings_dialog.py:48
msgid "Language:"
msgstr "Langue :"

#: src/pbrenamer/ui/main_window.py:131
msgid "Select folder"
msgstr "Choisir un dossier"

#: src/pbrenamer/ui/main_window.py:165 /tmp/_pbrenamer_ui_strings.py:38
msgid "Original"
msgstr "Original"

#: src/pbrenamer/ui/main_window.py:165 /tmp/_pbrenamer_ui_strings.py:37
#: /tmp/_pbrenamer_ui_strings.py:118
msgid "Preview"
msgstr "Aperçu"

#: src/pbrenamer/ui/main_window.py:177
#, python-brace-format
msgid "{path} — {n} item(s)"
msgstr "{path} — {n} élément(s)"

#: src/pbrenamer/ui/main_window.py:220
msgid ""
"Python regular expression · \\1 \\2… or \\g<name> for backreferences in the "
"replacement"
msgstr ""
"Expression rationnelle Python · \\1 \\2… ou \\g<nom> pour les rétro-"
"références dans le remplacement"

#: src/pbrenamer/ui/main_window.py:227
msgid ""
"Literal search · the search field is matched as-is against each file name"
msgstr ""
"Recherche littérale · le champ de recherche est comparé tel quel à chaque "
"nom de fichier"

#: src/pbrenamer/ui/main_window.py:234 /tmp/_pbrenamer_ui_strings.py:59
msgid ""
"{#} numbers · {L} letters · {C} non-space · {X} anything · {@} trash · {1} "
"{2}… capture groups · {num2} counter (zero-padded) · {date} today · {dir} "
"parent folder name"
msgstr ""
"{#} chiffres · {L} lettres · {C} sans espace · {X} tout · {@} poubelle · {1} "
"{2}… groupes capturés · {num2} compteur (zéros) · {date} aujourd'hui · {dir} "
"nom du dossier parent"

#: src/pbrenamer/ui/main_window.py:470
msgid "Rename errors"
msgstr "Erreurs de renommage"

#: src/pbrenamer/ui/main_window.py:506 /tmp/_pbrenamer_ui_strings.py:13
msgid "About PBRenamer"
msgstr "À propos de PBRenamer"

#: src/pbrenamer/ui/main_window.py:512
msgid "A graphical batch file renaming utility."
msgstr "Utilitaire graphique de renommage de fichiers en lot."

#: src/pbrenamer/ui/main_window.py:513
msgid "License: GPLv3"
msgstr "Licence : GPLv3"

#: src/pbrenamer/i18n.py:65 /tmp/_pbrenamer_ui_strings.py:133
msgid "language_name"
msgstr "Français"

#: /tmp/_pbrenamer_ui_strings.py:1
msgid "PBRenamer"
msgstr "PBRenamer"

#: /tmp/_pbrenamer_ui_strings.py:2
msgid "Open folder…"
msgstr "Ouvrir un dossier…"

#: /tmp/_pbrenamer_ui_strings.py:3
msgid "Ctrl+O"
msgstr ""

#: /tmp/_pbrenamer_ui_strings.py:4
msgid "Open a folder"
msgstr "Ouvrir un dossier"

#: /tmp/_pbrenamer_ui_strings.py:5
msgid "Open a directory chooser and navigate the tree to the selected folder"
msgstr ""
"Ouvre la fenêtre de sélection de dossier et positionne l'arborescence sur le "
"dossier choisi"

#: /tmp/_pbrenamer_ui_strings.py:6
msgid "Quit"
msgstr "Quitter"

#: /tmp/_pbrenamer_ui_strings.py:7
msgid "Ctrl+Q"
msgstr ""

#: /tmp/_pbrenamer_ui_strings.py:8
msgid "Quit PBRenamer"
msgstr "Quitter PBRenamer"

#: /tmp/_pbrenamer_ui_strings.py:9
msgid "Exit the application"
msgstr "Fermer l'application"

#: /tmp/_pbrenamer_ui_strings.py:10
msgid "Settings…"
msgstr "Préférences…"

#: /tmp/_pbrenamer_ui_strings.py:11
msgid "Open settings"
msgstr "Ouvrir les préférences"

#: /tmp/_pbrenamer_ui_strings.py:12
msgid "Configure language and other preferences"
msgstr "Configurer la langue et les autres préférences"

#: /tmp/_pbrenamer_ui_strings.py:14
msgid "About this application"
msgstr "À propos de cette application"

#: /tmp/_pbrenamer_ui_strings.py:15
msgid "Show version and license information"
msgstr "Afficher la version et la licence"

#: /tmp/_pbrenamer_ui_strings.py:16
msgid "Show:"
msgstr "Afficher :"

#: /tmp/_pbrenamer_ui_strings.py:17
msgid "Files only"
msgstr "Fichiers uniquement"

#: /tmp/_pbrenamer_ui_strings.py:18
msgid "Directories only"
msgstr "Dossiers uniquement"

#: /tmp/_pbrenamer_ui_strings.py:19
msgid "Files and directories"
msgstr "Fichiers et dossiers"

#: /tmp/_pbrenamer_ui_strings.py:20
msgid "Choose which entries to list"
msgstr "Choisir les entrées à afficher"

#: /tmp/_pbrenamer_ui_strings.py:21
msgid "List files only, directories only, or both"
msgstr "Afficher les fichiers uniquement, les dossiers uniquement, ou les deux"

#: /tmp/_pbrenamer_ui_strings.py:22
msgid "Recursive"
msgstr "Récursif"

#: /tmp/_pbrenamer_ui_strings.py:23
msgid "Include all subdirectories"
msgstr "Inclure tous les sous-dossiers"

#: /tmp/_pbrenamer_ui_strings.py:24
msgid "When checked, files from all subdirectories are listed"
msgstr "Lorsque coché, les fichiers de tous les sous-dossiers sont listés"

#: /tmp/_pbrenamer_ui_strings.py:25
msgid "Keep extension"
msgstr "Garder l'extension"

#: /tmp/_pbrenamer_ui_strings.py:26
msgid "Preserve the file extension"
msgstr "Conserver l'extension du fichier"

#: /tmp/_pbrenamer_ui_strings.py:27
msgid ""
"Apply transformations to the file stem only, leaving the extension unchanged"
msgstr ""
"Applique les transformations uniquement au nom de base, sans modifier "
"l'extension"

#: /tmp/_pbrenamer_ui_strings.py:28
msgid "Auto-preview"
msgstr "Aperçu automatique"

#: /tmp/_pbrenamer_ui_strings.py:29
msgid "Refresh the preview automatically"
msgstr "Actualiser l'aperçu automatiquement"

#: /tmp/_pbrenamer_ui_strings.py:30
msgid "Recompute the preview each time the pattern or options change"
msgstr "Recalcule l'aperçu à chaque modification du pattern ou des options"

#: /tmp/_pbrenamer_ui_strings.py:31
msgid "Filter:"
msgstr "Filtre :"

#: /tmp/_pbrenamer_ui_strings.py:32
msgid "*.txt"
msgstr "*.txt"

#: /tmp/_pbrenamer_ui_strings.py:33
msgid "Glob pattern to filter the file list"
msgstr "Pattern glob pour filtrer la liste de fichiers"

#: /tmp/_pbrenamer_ui_strings.py:34
msgid "Only files matching this glob pattern are listed (e.g. *.txt, image_*)"
msgstr ""
"Seuls les fichiers correspondant à ce pattern sont listés (ex. *.txt, "
"image_*)"

#: /tmp/_pbrenamer_ui_strings.py:35
msgid "Browse the filesystem"
msgstr "Parcourir le système de fichiers"

#: /tmp/_pbrenamer_ui_strings.py:36
msgid "Select a directory to list its contents in the panel on the right"
msgstr ""
"Sélectionner un dossier pour afficher son contenu dans le panneau de droite"

#: /tmp/_pbrenamer_ui_strings.py:39
msgid "Files to be renamed"
msgstr "Fichiers à renommer"

#: /tmp/_pbrenamer_ui_strings.py:40
msgid ""
"Select rows to restrict operations to those files; leave unselected to apply "
"to all"
msgstr ""
"Sélectionner des lignes pour restreindre les opérations à ces fichiers ; ne "
"rien sélectionner pour tout appliquer"

#: /tmp/_pbrenamer_ui_strings.py:41
msgid "Search:"
msgstr "Recherche :"

#: /tmp/_pbrenamer_ui_strings.py:42
msgid "Search pattern"
msgstr "Pattern de recherche"

#: /tmp/_pbrenamer_ui_strings.py:43
msgid ""
"Pattern to match against file names. Use tokens: {#} numbers, {L} letters, "
"{C} non-space, {X} anything"
msgstr ""
"Pattern à faire correspondre avec les noms de fichiers. Jetons : {#} "
"chiffres, {L} lettres, {C} sans espace, {X} tout"

#: /tmp/_pbrenamer_ui_strings.py:44
msgid "Pattern"
msgstr "Pattern"

#: /tmp/_pbrenamer_ui_strings.py:45
msgid "Search using pattern tokens"
msgstr "Rechercher avec des jetons de pattern"

#: /tmp/_pbrenamer_ui_strings.py:46
msgid "Match file names using pattern tokens ({#}, {L}, {X}…)"
msgstr ""
"Faire correspondre les noms de fichiers via des jetons ({#}, {L}, {X}…)"

#: /tmp/_pbrenamer_ui_strings.py:47
msgid "Regular expression"
msgstr "Expression rationnelle"

#: /tmp/_pbrenamer_ui_strings.py:48
msgid "Search using a Python regular expression"
msgstr "Rechercher avec une expression rationnelle Python"

#: /tmp/_pbrenamer_ui_strings.py:49
msgid ""
"Match file names using a Python regular expression; use \\1 \\2… for "
"backreferences in the replacement"
msgstr ""
"Faire correspondre les noms via une expression rationnelle Python ; utiliser "
"\\1 \\2… pour les rétro-références dans le remplacement"

#: /tmp/_pbrenamer_ui_strings.py:50
msgid "Plain text"
msgstr "Texte brut"

#: /tmp/_pbrenamer_ui_strings.py:51
msgid "Search for a literal string"
msgstr "Rechercher une chaîne littérale"

#: /tmp/_pbrenamer_ui_strings.py:52
msgid "Match file names by looking for the search text as a literal string"
msgstr ""
"Faire correspondre les noms de fichiers par recherche littérale du texte "
"saisi"

#: /tmp/_pbrenamer_ui_strings.py:53
msgid "Replace:"
msgstr "Remplacement :"

#: /tmp/_pbrenamer_ui_strings.py:54
msgid "Replacement pattern"
msgstr "Pattern de remplacement"

#: /tmp/_pbrenamer_ui_strings.py:55
#, python-brace-format
msgid ""
"Replacement pattern. Use {1} {2}… for capture groups, {num} for a counter, "
"{date} for today's date, {dir} for the parent folder name"
msgstr ""
"Pattern de remplacement. {1} {2}… pour les groupes capturés, {num} pour un "
"compteur, {date} pour la date du jour, {dir} pour le nom du dossier parent"

#: /tmp/_pbrenamer_ui_strings.py:56
msgid "Save pattern"
msgstr "Sauvegarder le pattern"

#: /tmp/_pbrenamer_ui_strings.py:57
msgid "Save this pattern pair to the history"
msgstr "Enregistrer cette paire de patterns dans l'historique"

#: /tmp/_pbrenamer_ui_strings.py:58
msgid ""
"Add the current search and replace patterns to the drop-down history for "
"reuse"
msgstr ""
"Ajoute les patterns actuels à l'historique des listes déroulantes pour une "
"réutilisation ultérieure"

#: /tmp/_pbrenamer_ui_strings.py:60
msgid "Patterns"
msgstr "Patterns"

#: /tmp/_pbrenamer_ui_strings.py:61
msgid "Spaces"
msgstr "Espaces"

#: /tmp/_pbrenamer_ui_strings.py:62
msgid "Spaces → underscores"
msgstr "Espaces → tirets bas"

#: /tmp/_pbrenamer_ui_strings.py:63
msgid "Underscores → spaces"
msgstr "Tirets bas → espaces"

#: /tmp/_pbrenamer_ui_strings.py:64
msgid "Spaces → dots"
msgstr "Espaces → points"

#: /tmp/_pbrenamer_ui_strings.py:65
msgid "Dots → spaces"
msgstr "Points → espaces"

#: /tmp/_pbrenamer_ui_strings.py:66
msgid "Spaces → dashes"
msgstr "Espaces → tirets"

#: /tmp/_pbrenamer_ui_strings.py:67
msgid "Dashes → spaces"
msgstr "Tirets → espaces"

#: /tmp/_pbrenamer_ui_strings.py:68
msgid "Separator substitution mode"
msgstr "Mode de substitution de séparateurs"

#: /tmp/_pbrenamer_ui_strings.py:69
msgid "Choose which separator characters to convert"
msgstr "Choisir les caractères séparateurs à convertir"

#: /tmp/_pbrenamer_ui_strings.py:70 /tmp/_pbrenamer_ui_strings.py:80
#: /tmp/_pbrenamer_ui_strings.py:97 /tmp/_pbrenamer_ui_strings.py:107
#: /tmp/_pbrenamer_ui_strings.py:114
msgid "Apply"
msgstr "Appliquer"

#: /tmp/_pbrenamer_ui_strings.py:71
msgid "Apply separator substitution"
msgstr "Appliquer la substitution de séparateurs"

#: /tmp/_pbrenamer_ui_strings.py:72
msgid "Apply the selected separator substitution to the file list preview"
msgstr ""
"Applique la substitution de séparateurs sélectionnée à l'aperçu de la liste "
"de fichiers"

#: /tmp/_pbrenamer_ui_strings.py:73
msgid "Capitalization"
msgstr "Casse"

#: /tmp/_pbrenamer_ui_strings.py:74
msgid "UPPERCASE"
msgstr "MAJUSCULES"

#: /tmp/_pbrenamer_ui_strings.py:75
msgid "lowercase"
msgstr "minuscules"

#: /tmp/_pbrenamer_ui_strings.py:76
msgid "Capitalize first letter"
msgstr "Première lettre en majuscule"

#: /tmp/_pbrenamer_ui_strings.py:77
msgid "Title Case"
msgstr "Première lettre de chaque mot"

#: /tmp/_pbrenamer_ui_strings.py:78
msgid "Capitalization mode"
msgstr "Mode de casse"

#: /tmp/_pbrenamer_ui_strings.py:79
msgid "Choose how to change the case of file names"
msgstr "Choisir comment modifier la casse des noms de fichiers"

#: /tmp/_pbrenamer_ui_strings.py:81
msgid "Apply capitalization"
msgstr "Appliquer la modification de casse"

#: /tmp/_pbrenamer_ui_strings.py:82
msgid "Apply the selected capitalization mode to the file list preview"
msgstr ""
"Applique le mode de casse sélectionné à l'aperçu de la liste de fichiers"

#: /tmp/_pbrenamer_ui_strings.py:83
msgid "Remove accents"
msgstr "Supprimer les accents"

#: /tmp/_pbrenamer_ui_strings.py:84
msgid "Strip diacritical marks"
msgstr "Supprimer les signes diacritiques"

#: /tmp/_pbrenamer_ui_strings.py:85
msgid "Convert accented characters to their ASCII equivalents (é→e, ü→u, etc.)"
msgstr ""
"Convertit les caractères accentués en leur équivalent ASCII (é→e, ü→u, etc.)"

#: /tmp/_pbrenamer_ui_strings.py:86
msgid "Remove duplicate separators"
msgstr "Supprimer les séparateurs en double"

#: /tmp/_pbrenamer_ui_strings.py:87
msgid "Collapse consecutive separators"
msgstr "Fusionner les séparateurs consécutifs"

#: /tmp/_pbrenamer_ui_strings.py:88
msgid ""
"Collapse runs of identical separator characters (spaces, dots, dashes, "
"underscores) into one"
msgstr ""
"Réduit les suites de séparateurs identiques (espaces, points, tirets, tirets "
"bas) à un seul"

#: /tmp/_pbrenamer_ui_strings.py:89
msgid "Substitutions"
msgstr "Substitutions"

#: /tmp/_pbrenamer_ui_strings.py:90
msgid "Insert"
msgstr "Insérer"

#: /tmp/_pbrenamer_ui_strings.py:91
msgid "Text:"
msgstr "Texte :"

#: /tmp/_pbrenamer_ui_strings.py:92
msgid "Text to insert"
msgstr "Texte à insérer"

#: /tmp/_pbrenamer_ui_strings.py:93
msgid "Characters to insert into each file name at the specified position"
msgstr "Caractères à insérer dans chaque nom de fichier à la position indiquée"

#: /tmp/_pbrenamer_ui_strings.py:94
msgid "at position:"
msgstr "à la position :"

#: /tmp/_pbrenamer_ui_strings.py:95
msgid "Character position (0 = start)"
msgstr "Position du caractère (0 = début)"

#: /tmp/_pbrenamer_ui_strings.py:96
msgid ""
"Zero-based character index at which to insert the text; use a high value to "
"append"
msgstr ""
"Index de caractère (base 0) où insérer le texte ; utiliser une valeur élevée "
"pour ajouter en fin de nom"

#: /tmp/_pbrenamer_ui_strings.py:98
msgid "Apply insertion"
msgstr "Appliquer l'insertion"

#: /tmp/_pbrenamer_ui_strings.py:99
msgid ""
"Insert the given text at the specified position in the file list preview"
msgstr ""
"Insère le texte à la position indiquée dans l'aperçu de la liste de fichiers"

#: /tmp/_pbrenamer_ui_strings.py:100
msgid "Delete"
msgstr "Supprimer"

#: /tmp/_pbrenamer_ui_strings.py:101
msgid "From position:"
msgstr "De la position :"

#: /tmp/_pbrenamer_ui_strings.py:102
msgid "Start of the range to delete (0 = first character)"
msgstr "Début de la plage à supprimer (0 = premier caractère)"

#: /tmp/_pbrenamer_ui_strings.py:103
msgid "Index of the first character to delete (zero-based, inclusive)"
msgstr "Index du premier caractère à supprimer (base 0, inclus)"

#: /tmp/_pbrenamer_ui_strings.py:104
msgid "to:"
msgstr "à :"

#: /tmp/_pbrenamer_ui_strings.py:105
msgid "End of the range to delete (inclusive)"
msgstr "Fin de la plage à supprimer (incluse)"

#: /tmp/_pbrenamer_ui_strings.py:106
msgid "Index of the last character to delete (zero-based, inclusive)"
msgstr "Index du dernier caractère à supprimer (base 0, inclus)"

#: /tmp/_pbrenamer_ui_strings.py:108
msgid "Apply deletion"
msgstr "Appliquer la suppression"

#: /tmp/_pbrenamer_ui_strings.py:109
msgid ""
"Delete the specified character range from each name in the file list preview"
msgstr ""
"Supprime la plage de caractères indiquée dans chaque nom de la liste de "
"fichiers"

#: /tmp/_pbrenamer_ui_strings.py:110
msgid "Insert / Delete"
msgstr "Insérer / Supprimer"

#: /tmp/_pbrenamer_ui_strings.py:111
msgid "New name for selected file:"
msgstr "Nouveau nom pour le fichier sélectionné :"

#: /tmp/_pbrenamer_ui_strings.py:112
msgid "New name for the selected file"
msgstr "Nouveau nom pour le fichier sélectionné"

#: /tmp/_pbrenamer_ui_strings.py:113
msgid "Type the new name for the currently selected file, then click Apply"
msgstr ""
"Saisir le nouveau nom du fichier sélectionné, puis cliquer sur Appliquer"

#: /tmp/_pbrenamer_ui_strings.py:115
msgid "Set the preview name for the selected file"
msgstr "Définir le nom en aperçu pour le fichier sélectionné"

#: /tmp/_pbrenamer_ui_strings.py:116
msgid "Apply the typed name as the preview for the currently selected file"
msgstr "Utilise le nom saisi comme aperçu pour le fichier sélectionné"

#: /tmp/_pbrenamer_ui_strings.py:117
msgid "Manual"
msgstr "Manuel"

#: /tmp/_pbrenamer_ui_strings.py:119
msgid "Compute rename preview"
msgstr "Calculer l'aperçu du renommage"

#: /tmp/_pbrenamer_ui_strings.py:120
msgid ""
"Apply the current pattern to all listed files and show the result in the "
"Preview column"
msgstr ""
"Applique le pattern actuel à tous les fichiers listés et affiche le résultat "
"dans la colonne Aperçu"

#: /tmp/_pbrenamer_ui_strings.py:121
msgid "Clear"
msgstr "Effacer"

#: /tmp/_pbrenamer_ui_strings.py:122
msgid "Clear the preview"
msgstr "Effacer l'aperçu"

#: /tmp/_pbrenamer_ui_strings.py:123
msgid "Remove all preview values from the Preview column"
msgstr "Supprime toutes les valeurs de la colonne Aperçu"

#: /tmp/_pbrenamer_ui_strings.py:124
msgid "Undo"
msgstr "Annuler"

#: /tmp/_pbrenamer_ui_strings.py:125
msgid "Undo last rename batch"
msgstr "Annuler le dernier lot de renommage"

#: /tmp/_pbrenamer_ui_strings.py:126
msgid "Reverse the last batch of renames performed on disk"
msgstr "Inverse le dernier lot de renommages effectués sur le disque"

#: /tmp/_pbrenamer_ui_strings.py:127
msgid "Rename"
msgstr "Renommer"

#: /tmp/_pbrenamer_ui_strings.py:128
msgid "Apply renames on disk"
msgstr "Appliquer les renommages sur le disque"

#: /tmp/_pbrenamer_ui_strings.py:129
msgid ""
"Permanently rename all files shown in the Preview column (only enabled when "
"there are no conflicts)"
msgstr ""
"Renomme définitivement tous les fichiers affichés dans la colonne Aperçu "
"(actif uniquement s'il n'y a pas de conflit)"

#: /tmp/_pbrenamer_ui_strings.py:130
msgid "File"
msgstr "Fichier"

#: /tmp/_pbrenamer_ui_strings.py:131
msgid "Edit"
msgstr "Édition"

#: /tmp/_pbrenamer_ui_strings.py:132
msgid "Help"
msgstr "Aide"

#~ msgid "Enable Python regular expressions"
#~ msgstr "Activer les expressions rationnelles Python"

#~ msgid ""
#~ "When checked, the search field accepts Python regular expressions instead "
#~ "of pattern tokens"
#~ msgstr ""
#~ "Lorsque cochée, le champ de recherche accepte des expressions "
#~ "rationnelles Python à la place des jetons de pattern"

#~ msgid "Replace text"
#~ msgstr "Remplacer du texte"

#~ msgid "Find:"
#~ msgstr "Chercher :"

#~ msgid "Text to search for"
#~ msgstr "Texte à rechercher"

#~ msgid "Literal string to find in each file name"
#~ msgstr "Chaîne de caractères à trouver dans chaque nom de fichier"

#~ msgid "→"
#~ msgstr "→"

#~ msgid "Replacement text"
#~ msgstr "Texte de remplacement"

#~ msgid "String to substitute in place of every occurrence found"
#~ msgstr "Chaîne à substituer à chaque occurrence trouvée"

