<ui version="4.0">
 <class>HistoryDialog</class>
 <widget class="QDialog" name="HistoryDialog">
  <property name="geometry">
   <rect><x>0</x><y>0</y><width>640</width><height>400</height></rect>
  </property>
  <property name="minimumSize">
   <size><width>620</width><height>360</height></size>
  </property>
  <property name="windowTitle">
   <string>History</string>
  </property>
  <layout class="QVBoxLayout" name="mainLayout">
   <item>
    <layout class="QHBoxLayout" name="panelsLayout">

     <!-- Search group -->
     <item>
      <widget class="QGroupBox" name="grpSearch">
       <property name="title"><string>Search</string></property>
       <layout class="QVBoxLayout" name="layoutSearch">
        <item>
         <widget class="QListWidget" name="lstSearch">
          <property name="selectionMode">
           <enum>QAbstractItemView::ExtendedSelection</enum>
          </property>
          <property name="toolTip"><string>Search pattern history</string></property>
          <property name="statusTip"><string>Select one or more entries to remove them</string></property>
         </widget>
        </item>
        <item>
         <layout class="QHBoxLayout" name="addSearchLayout">
          <item>
           <widget class="WhitespaceLineEdit" name="edtSearch">
            <property name="placeholderText"><string>Pattern…</string></property>
            <property name="toolTip"><string>New search pattern to add</string></property>
           </widget>
          </item>
          <item>
           <widget class="QRadioButton" name="radPattern">
            <property name="text"><string>pat</string></property>
            <property name="checked"><bool>true</bool></property>
            <property name="toolTip"><string>Pattern token mode</string></property>
           </widget>
          </item>
          <item>
           <widget class="QRadioButton" name="radRegex">
            <property name="text"><string>RE</string></property>
            <property name="toolTip"><string>Regular expression mode</string></property>
           </widget>
          </item>
          <item>
           <widget class="QRadioButton" name="radPlainText">
            <property name="text"><string>txt</string></property>
            <property name="toolTip"><string>Plain text mode</string></property>
           </widget>
          </item>
          <item>
           <widget class="QPushButton" name="btnAddSearch">
            <property name="text"><string>Add</string></property>
            <property name="toolTip"><string>Add this pattern to the search history</string></property>
           </widget>
          </item>
         </layout>
        </item>
        <item>
         <layout class="QHBoxLayout" name="actionsSearchLayout">
          <item>
           <widget class="QPushButton" name="btnRemoveSearch">
            <property name="text"><string>Remove</string></property>
            <property name="toolTip"><string>Remove selected entries</string></property>
            <property name="statusTip"><string>Delete the selected search history entries</string></property>
           </widget>
          </item>
          <item>
           <widget class="QPushButton" name="btnClearSearch">
            <property name="text"><string>Clear all</string></property>
            <property name="toolTip"><string>Remove all search history entries</string></property>
            <property name="statusTip"><string>Delete the entire search pattern history</string></property>
           </widget>
          </item>
          <item>
           <spacer>
            <property name="orientation"><enum>Qt::Horizontal</enum></property>
            <property name="sizeHint" stdset="0">
             <size><width>40</width><height>20</height></size>
            </property>
           </spacer>
          </item>
         </layout>
        </item>
       </layout>
      </widget>
     </item>

     <!-- Replace group -->
     <item>
      <widget class="QGroupBox" name="grpReplace">
       <property name="title"><string>Replace</string></property>
       <layout class="QVBoxLayout" name="layoutReplace">
        <item>
         <widget class="QListWidget" name="lstReplace">
          <property name="selectionMode">
           <enum>QAbstractItemView::ExtendedSelection</enum>
          </property>
          <property name="toolTip"><string>Replacement pattern history</string></property>
          <property name="statusTip"><string>Select one or more entries to remove them</string></property>
