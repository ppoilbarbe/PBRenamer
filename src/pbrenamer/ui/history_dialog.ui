        </item>
        <item>
         <layout class="QHBoxLayout" name="addReplaceLayout">
          <item>
           <widget class="WhitespaceLineEdit" name="edtReplace">
            <property name="placeholderText"><string>Pattern…</string></property>
            <property name="toolTip"><string>New replacement pattern to add</string></property>
