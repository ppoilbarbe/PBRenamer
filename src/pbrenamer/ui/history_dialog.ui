          </item>
          <item>
           <widget class="QPushButton" name="btnClearReplace">
            <property name="text"><string>Clear all</string></property>
            <property name="toolTip"><string>Remove all replacement history entries</string></property>
            <property name="statusTip"><string>Delete the entire replacement pattern history</string></property>
