        </widget>

        <!-- Tab 3: Manual -->
        <widget class="QWidget" name="tabManual">
         <attribute name="title"><string>Manual</string></attribute>
         <layout class="QVBoxLayout" name="layoutManual">
          <item>
           <layout class="QHBoxLayout">
            <item>
             <widget class="QLabel">
              <property name="text"><string>New name for selected file:</string></property>
             </widget>
            </item>
            <item>
             <widget class="QLineEdit" name="edtManualName">
