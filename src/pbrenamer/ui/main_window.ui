<?xml version="1.0" encoding="UTF-8"?>
<ui version="4.0">
 <class>MainWindow</class>
 <widget class="QMainWindow" name="MainWindow">
  <property name="geometry">
   <rect><x>0</x><y>0</y><width>1100</width><height>720</height></rect>
  </property>
  <property name="minimumSize">
   <size><width>900</width><height>600</height></size>
  </property>
  <property name="windowTitle">
   <string>PBRenamer</string>
  </property>

  <widget class="QWidget" name="centralwidget">
   <layout class="QVBoxLayout" name="verticalLayout" stretch="0,1">

    <!-- ── Options bar ──────────────────────────────────────────────── -->
    <item>
     <layout class="QHBoxLayout" name="optionsLayout">
      <item>
       <widget class="QLabel" name="lblShow">
        <property name="text"><string>Show:</string></property>
       </widget>
      </item>
      <item>
       <widget class="QComboBox" name="cmbMode">
        <property name="toolTip"><string>Choose which entries to list</string></property>
        <property name="statusTip"><string>List files only, directories only, or both</string></property>
        <item><property name="text"><string>Files only</string></property></item>
        <item><property name="text"><string>Directories only</string></property></item>
        <item><property name="text"><string>Files and directories</string></property></item>
       </widget>
      </item>
      <item>
       <widget class="QCheckBox" name="chkRecursive">
        <property name="text"><string>Recursive</string></property>
        <property name="toolTip"><string>Include all subdirectories</string></property>
        <property name="statusTip"><string>When checked, files from all subdirectories are listed</string></property>
       </widget>
      </item>
      <item>
       <widget class="QCheckBox" name="chkKeepExtension">
        <property name="text"><string>Keep extension</string></property>
        <property name="checked"><bool>true</bool></property>
        <property name="toolTip"><string>Preserve the file extension</string></property>
        <property name="statusTip"><string>Apply transformations to the file stem only, leaving the extension unchanged</string></property>
       </widget>
      </item>
      <item>
       <widget class="QCheckBox" name="chkAutoPreview">
        <property name="text"><string>Auto-preview</string></property>
        <property name="toolTip"><string>Refresh the preview automatically</string></property>
        <property name="statusTip"><string>Recompute the preview each time the pattern or options change</string></property>
       </widget>
      </item>
      <item>
       <widget class="QLabel" name="lblFilter">
        <property name="text"><string>Filter:</string></property>
       </widget>
      </item>
      <item>
       <widget class="QLineEdit" name="edtFilter">
        <property name="placeholderText"><string>*.txt</string></property>
        <property name="maximumWidth"><number>160</number></property>
        <property name="toolTip"><string>Glob pattern to filter the file list</string></property>
        <property name="statusTip"><string>Only files matching this glob pattern are listed (e.g. *.txt, image_*)</string></property>
       </widget>
      </item>
      <item>
       <spacer name="hSpacer2">
        <property name="orientation"><enum>Qt::Horizontal</enum></property>
        <property name="sizeHint" stdset="0">
         <size><width>20</width><height>20</height></size>
        </property>
       </spacer>
      </item>
     </layout>
    </item>

    <!-- ── Main splitter (left tree | right panel) ─────────────────── -->
    <item>
     <widget class="QSplitter" name="splitterMain">
      <property name="orientation"><enum>Qt::Horizontal</enum></property>

      <!-- Left: directory tree -->
      <widget class="QTreeView" name="treeDirectory">
       <property name="minimumWidth"><number>180</number></property>
       <property name="headerHidden"><bool>true</bool></property>
       <property name="toolTip"><string>Browse the filesystem</string></property>
       <property name="statusTip"><string>Select a directory to list its contents in the panel on the right</string></property>
      </widget>

      <!-- Right: vertical splitter (file list | bottom panel) -->
      <widget class="QSplitter" name="splitterRight">
       <property name="orientation"><enum>Qt::Vertical</enum></property>

       <!-- File list: Original | Preview -->
       <widget class="QTreeWidget" name="tblFiles">
        <property name="selectionMode"><enum>QAbstractItemView::ExtendedSelection</enum></property>
        <property name="alternatingRowColors"><bool>true</bool></property>
        <property name="rootIsDecorated"><bool>false</bool></property>
        <property name="sortingEnabled"><bool>false</bool></property>
        <property name="toolTip"><string>Files to be renamed</string></property>
        <property name="statusTip"><string>Select rows to restrict operations to those files; leave unselected to apply to all</string></property>
        <column>
         <property name="text"><string>Original</string></property>
        </column>
        <column>
         <property name="text"><string>Preview</string></property>
        </column>
       </widget>

       <!-- Bottom panel: rename controls + action buttons -->
       <widget class="QWidget" name="bottomPanel">
        <layout class="QHBoxLayout" name="bottomLayout">
         <property name="leftMargin"><number>0</number></property>
         <property name="topMargin"><number>0</number></property>
         <property name="rightMargin"><number>0</number></property>
         <property name="bottomMargin"><number>0</number></property>
         <item>

          <!-- Rename controls frame -->
          <widget class="QFrame" name="renameFrame">
           <property name="frameShape"><enum>QFrame::StyledPanel</enum></property>
           <property name="frameShadow"><enum>QFrame::Raised</enum></property>
           <layout class="QVBoxLayout" name="layoutPatterns">
            <item>
             <layout class="QHBoxLayout">
              <item>
               <widget class="QLabel">
                <property name="text"><string>Search:</string></property>
                <property name="minimumWidth"><number>60</number></property>
               </widget>
              </item>
              <item>
               <widget class="QComboBox" name="cmbPatternSearch">
                <property name="editable"><bool>true</bool></property>
                <property name="sizePolicy">
                 <sizepolicy hsizetype="Expanding" vsizetype="Fixed">
                  <horstretch>1</horstretch><verstretch>0</verstretch>
                 </sizepolicy>
                </property>
                <property name="toolTip"><string>Search pattern</string></property>
                <property name="statusTip"><string>Pattern to match against file names. Use tokens: {#} numbers, {L} letters, {C} non-space, {X} anything</string></property>
               </widget>
              </item>
              <item>
               <widget class="QToolButton" name="btnSearchAdd">
                <property name="autoRaise"><bool>true</bool></property>
                <property name="toolTip"><string>Save to history</string></property>
                <property name="statusTip"><string>Add the current search pattern and mode to the drop-down history</string></property>
               </widget>
              </item>
              <item>
               <widget class="QToolButton" name="btnSearchHelp">
                <property name="autoRaise"><bool>true</bool></property>
                <property name="toolTip"><string>Search pattern help</string></property>
                <property name="statusTip"><string>Show help about search patterns (Pattern tokens, Regular expressions, Plain text)</string></property>
               </widget>
              </item>
             </layout>
            </item>
            <item>
             <layout class="QHBoxLayout">
              <item>
               <widget class="QRadioButton" name="radPattern">
                <property name="text"><string>Pattern</string></property>
                <property name="checked"><bool>true</bool></property>
                <property name="toolTip"><string>Search using pattern tokens</string></property>
                <property name="statusTip"><string>Match file names using pattern tokens ({#}, {L}, {X}…)</string></property>
               </widget>
              </item>
              <item>
               <widget class="QRadioButton" name="radRegex">
                <property name="text"><string>Regular expression</string></property>
                <property name="toolTip"><string>Search using a Python regular expression</string></property>
                <property name="statusTip"><string>Match file names using a Python regular expression; use \1 \2… for backreferences in the replacement</string></property>
               </widget>
              </item>
              <item>
               <widget class="QRadioButton" name="radPlainText">
                <property name="text"><string>Plain text</string></property>
                <property name="toolTip"><string>Search for a literal string</string></property>
                <property name="statusTip"><string>Match file names by looking for the search text as a literal string</string></property>
               </widget>
              </item>
              <item>
               <spacer>
                <property name="orientation"><enum>Qt::Horizontal</enum></property>
                <property name="sizeHint" stdset="0">
                 <size><width>40</width><height>20</height></size>
                </property>
               </spacer>
              </item>
             </layout>
            </item>
            <item>
             <layout class="QHBoxLayout">
              <item>
               <widget class="QLabel">
                <property name="text"><string>Replace:</string></property>
                <property name="minimumWidth"><number>60</number></property>
               </widget>
              </item>
              <item>
               <widget class="QComboBox" name="cmbPatternDest">
                <property name="editable"><bool>true</bool></property>
                <property name="sizePolicy">
                 <sizepolicy hsizetype="Expanding" vsizetype="Fixed">
                  <horstretch>1</horstretch><verstretch>0</verstretch>
                 </sizepolicy>
                </property>
                <property name="toolTip"><string>Replacement pattern</string></property>
                <property name="statusTip"><string>Replacement pattern. Use {1} {2}… for capture groups, {num} for a counter, {date} for today's date, {dir} for the parent folder name</string></property>
               </widget>
              </item>
              <item>
               <widget class="QToolButton" name="btnReplaceAdd">
                <property name="autoRaise"><bool>true</bool></property>
                <property name="toolTip"><string>Save to history</string></property>
                <property name="statusTip"><string>Add the current replacement pattern to the drop-down history</string></property>
               </widget>
              </item>
              <item>
               <widget class="QToolButton" name="btnReplaceHelp">
                <property name="autoRaise"><bool>true</bool></property>
                <property name="toolTip"><string>Replacement pattern help</string></property>
                <property name="statusTip"><string>Show help about replacement patterns (capture groups, counter, date, directory tokens)</string></property>
               </widget>
              </item>
             </layout>
            </item>
            <item>
             <layout class="QHBoxLayout">
              <item>
               <widget class="QLabel">
                <property name="text"><string>Separator:</string></property>
                <property name="minimumWidth"><number>60</number></property>
               </widget>
              </item>
              <item>
               <widget class="QComboBox" name="cmbSpaces">
                <property name="toolTip"><string>Separator shortcut</string></property>
                <property name="statusTip"><string>Select a separator conversion to fill in the search and replacement fields in regex mode</string></property>
                <item><property name="text"><string>— Separator shortcuts —</string></property></item>
                <item><property name="text"><string>Spaces → underscores</string></property></item>
                <item><property name="text"><string>Underscores → spaces</string></property></item>
                <item><property name="text"><string>Spaces → dots</string></property></item>
                <item><property name="text"><string>Dots → spaces</string></property></item>
                <item><property name="text"><string>Spaces → dashes</string></property></item>
                <item><property name="text"><string>Dashes → spaces</string></property></item>
               </widget>
              </item>
              <item>
               <spacer>
                <property name="orientation"><enum>Qt::Horizontal</enum></property>
                <property name="sizeHint" stdset="0">
                 <size><width>40</width><height>20</height></size>
                </property>
               </spacer>
              </item>
             </layout>
            </item>
            <item>
             <spacer>
              <property name="orientation"><enum>Qt::Vertical</enum></property>
              <property name="sizeHint" stdset="0">
               <size><width>20</width><height>5</height></size>
              </property>
             </spacer>
            </item>
            <item>
             <widget class="QGroupBox" name="grpPostProcess">
              <property name="title"><string>Post-processing</string></property>
              <property name="minimumHeight"><number>60</number></property>
              <layout class="QHBoxLayout">
               <item>
                <widget class="QCheckBox" name="chkRemoveAccents">
                 <property name="text"><string>Remove accents</string></property>
                 <property name="toolTip"><string>Strip diacritical marks</string></property>
                 <property name="statusTip"><string>Convert accented characters to their ASCII equivalents (é→e, ü→u, etc.)</string></property>
                </widget>
               </item>
               <item>
                <widget class="QCheckBox" name="chkRemoveDuplicates">
                 <property name="text"><string>Remove duplicate separators</string></property>
                 <property name="toolTip"><string>Collapse consecutive separators</string></property>
                 <property name="statusTip"><string>Collapse runs of identical separator characters (spaces, dots, dashes, underscores) into one</string></property>
                </widget>
               </item>
               <item>
                <widget class="QLabel">
                 <property name="text"><string>Case:</string></property>
                </widget>
               </item>
               <item>
                <widget class="QComboBox" name="cmbCaps">
                 <property name="toolTip"><string>Capitalization mode</string></property>
                 <property name="statusTip"><string>Choose how to change the case of file names after applying the pattern</string></property>
                 <item><property name="text"><string>No change</string></property></item>
                 <item><property name="text"><string>UPPERCASE</string></property></item>
                 <item><property name="text"><string>lowercase</string></property></item>
                 <item><property name="text"><string>Capitalize first letter</string></property></item>
                 <item><property name="text"><string>Title Case</string></property></item>
                </widget>
               </item>
               <item>
                <spacer>
                 <property name="orientation"><enum>Qt::Horizontal</enum></property>
                 <property name="sizeHint" stdset="0">
                  <size><width>40</width><height>20</height></size>
                 </property>
                </spacer>
               </item>
              </layout>
             </widget>
            </item>
           </layout>
          </widget><!-- /renameFrame -->
         </item>

         <!-- Action buttons (vertical bar on the right) -->
         <item>
          <layout class="QVBoxLayout" name="actionButtonsLayout">
           <item>
            <widget class="QPushButton" name="btnPreview">
             <property name="text"><string>Preview</string></property>
             <property name="toolTip"><string>Compute rename preview</string></property>
             <property name="statusTip"><string>Apply the current pattern to all listed files and show the result in the Preview column</string></property>
            </widget>
           </item>
           <item>
            <widget class="QPushButton" name="btnClearPreview">
             <property name="text"><string>Clear</string></property>
             <property name="toolTip"><string>Clear the preview</string></property>
             <property name="statusTip"><string>Remove all preview values from the Preview column</string></property>
            </widget>
           </item>
           <item>
            <spacer name="vSpacerActions">
             <property name="orientation"><enum>Qt::Vertical</enum></property>
             <property name="sizeHint" stdset="0">
              <size><width>20</width><height>40</height></size>
             </property>
            </spacer>
           </item>
           <item>
            <widget class="QPushButton" name="btnUndo">
             <property name="enabled"><bool>false</bool></property>
             <property name="text"><string>Undo</string></property>
             <property name="toolTip"><string>Undo last rename batch</string></property>
             <property name="statusTip"><string>Reverse the last batch of renames performed on disk</string></property>
            </widget>
           </item>
           <item>
            <widget class="QPushButton" name="btnRename">
             <property name="enabled"><bool>false</bool></property>
             <property name="text"><string>Rename</string></property>
             <property name="toolTip"><string>Apply renames on disk</string></property>
             <property name="statusTip"><string>Permanently rename all files shown in the Preview column (only enabled when there are no conflicts)</string></property>
            </widget>
           </item>
          </layout>
         </item>

        </layout>
       </widget><!-- /bottomPanel -->

      </widget><!-- /splitterRight -->
     </widget><!-- /splitterMain -->
    </item>

   </layout>
  </widget><!-- /centralwidget -->

  <widget class="QStatusBar" name="statusbar"/>

  <widget class="QMenuBar" name="menubar">
   <property name="geometry">
    <rect><x>0</x><y>0</y><width>1100</width><height>30</height></rect>
   </property>
   <widget class="QMenu" name="menuFile">
    <property name="title"><string>File</string></property>
    <addaction name="actionOpenFolder"/>
    <addaction name="separator"/>
    <addaction name="actionQuit"/>
   </widget>
   <widget class="QMenu" name="menuEdit">
    <property name="title"><string>Edit</string></property>
    <addaction name="actionHistory"/>
    <addaction name="separator"/>
    <addaction name="actionSettings"/>
   </widget>
   <widget class="QMenu" name="menuHelp">
    <property name="title"><string>Help</string></property>
    <addaction name="actionAbout"/>
   </widget>
   <addaction name="menuFile"/>
   <addaction name="menuEdit"/>
   <addaction name="menuHelp"/>
  </widget>

  <action name="actionOpenFolder">
   <property name="text"><string>Open folder…</string></property>
   <property name="shortcut"><string>Ctrl+O</string></property>
   <property name="toolTip"><string>Open a folder</string></property>
   <property name="statusTip"><string>Open a directory chooser and navigate the tree to the selected folder</string></property>
  </action>
  <action name="actionQuit">
   <property name="text"><string>Quit</string></property>
   <property name="shortcut"><string>Ctrl+Q</string></property>
   <property name="toolTip"><string>Quit PBRenamer</string></property>
   <property name="statusTip"><string>Exit the application</string></property>
  </action>
  <action name="actionHistory">
   <property name="text"><string>History…</string></property>
   <property name="toolTip"><string>Manage pattern history</string></property>
   <property name="statusTip"><string>Add or remove entries from the search and replacement pattern history</string></property>
  </action>
  <action name="actionSettings">
   <property name="text"><string>Settings…</string></property>
   <property name="toolTip"><string>Open settings</string></property>
   <property name="statusTip"><string>Configure language and other preferences</string></property>
  </action>
  <action name="actionAbout">
   <property name="text"><string>About PBRenamer</string></property>
   <property name="toolTip"><string>About this application</string></property>
   <property name="statusTip"><string>Show version and license information</string></property>
  </action>

 </widget>
 <resources/>
 <connections/>
</ui>
